                <style>
                    /* Base visual del widget de reportes */
                    #reports-widget * {
                        box-sizing: border-box;
                        font-family: Roboto, Arial, Helvetica, sans-serif;
                    }

                    /* Contenedor principal del modulo */
                    #reports-widget .container {
                        max-width: 1120px;
                        margin: 12px auto;
                        padding: 0 10px;
                    }

                    /* Tarjeta principal de reportes */
                    #reports-widget .card {
                        background: #004D61;
background: radial-gradient(circle,rgba(0, 77, 97, 1) 0%, rgba(0, 0, 0, 1) 100%);
                        border-radius: 8px;
                        padding: 12px;
                        box-shadow: 0 6px 20px rgba(2, 6, 23, 0.06);
                    }

                    #reports-widget .card-title {
                        margin: 0;
                        color: #f6f7f8;
                        font-size: 1rem;
                    }

                    /* Rejilla de filtros por fecha, vehiculo, chofer, etc. */
                    #reports-widget .filters-grid {
                        display: grid;
                        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
                        gap: 8px;
                        margin: 10px 0;
                    }

                    #reports-widget .filter-field {
                        display: flex;
                        flex-direction: column;
                        gap: 3px;
                    }

                    #reports-widget .filter-label {
                        font-size: 12px;
                        font-weight: 700;
                        color: #51606d;
                    }

                    /* Controles y campos de entrada */
                    #reports-widget .form-control {
                        width: 100%;
                        padding: 7px 8px;
                        border: 1px solid #d8dbe1;
                        border-radius: 6px;
                        font-size: 13px;
                    }

                    /* Grupo de botones de acciones y exportacion */
                    #reports-widget .buttons-wrap {
                        display: flex;
                        flex-wrap: wrap;
                        gap: 6px;
                        margin-bottom: 8px;
                    }

                    #reports-widget .btn {
                        border: 0;
                        border-radius: 6px;
                        padding: 6px 9px;
                        color: #fff;
                        background: #1f7ab2;
                        cursor: pointer;
                        font-weight: 600;
                        font-size: 12px;
                    }

                    #reports-widget .btn.secondary { background: #4c5a67; }
                    #reports-widget .btn.success { background: #1f8b4c; }
                    #reports-widget .btn.warning { background: #b56f0b; }
                    #reports-widget .btn.danger { background: #b63737; }
                    #reports-widget .btn.is-active {
                        box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.28) inset;
                        transform: translateY(-1px);
                    }

                    #reports-widget .report-quick-grid {
                        display: grid;
                        grid-template-columns: 220px auto;
                        gap: 8px;
                        margin-top: 6px;
                        align-items: center;
                    }

                    #reports-widget .report-state {
                        grid-column: 1 / -1;
                        color: #dbeafe;
                        font-size: 12px;
                        background: rgba(15, 23, 42, 0.36);
                        border: 1px solid rgba(148, 163, 184, 0.35);
                        border-radius: 8px;
                        padding: 6px 8px;
                    }

                    #reports-widget .btn[disabled] {
                        opacity: 0.55;
                        cursor: not-allowed;
                    }

                    #reports-widget .advanced-filters {
                        margin: 8px 0 10px;
                        border: 1px solid rgba(148, 163, 184, 0.35);
                        border-radius: 8px;
                        padding: 8px;
                        background: rgba(2, 6, 23, 0.2);
                    }

                    #reports-widget .advanced-filters summary {
                        cursor: pointer;
                        color: #cbd5e1;
                        font-size: 12px;
                        font-weight: 700;
                    }

                    #reports-widget .advanced-filters-content {
                        margin-top: 8px;
                    }

                    /* Tabla de vista previa e historial */
                    #reports-widget .table-container {
                        overflow-x: auto;
                        margin-top: 6px;
                    }

                    #reports-widget table {
                        width: 100%;
                        border-collapse: collapse;
                    }

                    #reports-widget th,
                    #reports-widget td {
                        text-align: left;
                        border-bottom: 1px solid #edf1f4;
                        padding: 7px;
                        white-space: nowrap;
                        font-size: 13px;
                    }

                    #reports-widget .section-title {
                        margin: 10px 0 6px;
                        color: #edf1f3;
                        font-size: 0.95rem;
                    }

                    /* Tarjetas KPI de resumen */
                    #reports-widget .kpi-grid {
                        display: grid;
                        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
                        gap: 8px;
                        margin: 8px 0 10px;
                    }

                    #reports-widget .kpi-card {
                        background: #fefbf7;
                        border: 1px solid #dfeaf1;
                        border-radius: 8px;
                        padding: 8px 9px;
                    }

                    #reports-widget .kpi-label {
                        font-size: 12px;
                        color: #5b6b77;
                    }

                    #reports-widget .kpi-value {
                        font-size: 1.1rem;
                        font-weight: 700;
                        color: #0f3750;
                    }

                    #reports-widget .kpi-value.kpi-good { color: #166534; }
                    #reports-widget .kpi-value.kpi-warn { color: #9a6500; }
                    #reports-widget .kpi-value.kpi-bad { color: #9f1239; }

                    /* Estado vacio cuando no hay datos */
                    #reports-widget .empty {
                        text-align: center;
                        color: #6c7a86;
                        padding: 16px;
                    }
                </style>

