            const mexicoBounds = [[14.0, -118.5], [33.0, -86.0]];

            if (!statusFilter || !clientFilter || !driverFilter || !tripSelector || !tableBody || !tripEmpty) return;

            if (tripsDownloadInfoModal && tripsDownloadInfoModal.parentElement !== document.body) {
                document.body.appendChild(tripsDownloadInfoModal);
            }

            function fillTripsEditModal(trip) {
                if (!trip) return;
                if (tripsEditTripId) tripsEditTripId.value = safeText(trip.trip_id) === '-' ? '' : safeText(trip.trip_id);
                if (tripsEditEstado) tripsEditEstado.value = String(trip.estado_viaje || '').trim().toLowerCase() || 'programado';
                if (tripsEditOrigen) tripsEditOrigen.value = safeText(trip.origen) === '-' ? '' : safeText(trip.origen);
                if (tripsEditDestino) tripsEditDestino.value = safeText(trip.destino) === '-' ? '' : safeText(trip.destino);
                if (tripsEditConductor) tripsEditConductor.value = safeText(trip.conductor) === '-' ? '' : safeText(trip.conductor);
                if (tripsEditCliente) tripsEditCliente.value = safeText(trip.cliente) === '-' ? '' : safeText(trip.cliente);
                if (tripsEditVehiculo) tripsEditVehiculo.value = safeText(trip.vehiculo_asignado) === '-' ? '' : safeText(trip.vehiculo_asignado);
                if (tripsEditUbicacion) tripsEditUbicacion.value = safeText(trip.ubicacion_actual) === '-' ? '' : safeText(trip.ubicacion_actual);
            }

            function showTripsDownloadModal(tripToEdit) {
                if (!tripsDownloadInfoModal || tripsDownloadInfoModal.classList.contains('is-open')) return;
                if (!tripToEdit) {
                    alert('No hay un viaje seleccionado para editar.');
                    return;
                }
                fillTripsEditModal(tripToEdit);
                tripsDownloadInfoModal.classList.add('is-open');
                tripsDownloadInfoModal.setAttribute('aria-hidden', 'false');
                document.body.classList.add('users-modal-open');
            }

            function hideTripsDownloadModal() {
                if (!tripsDownloadInfoModal || !tripsDownloadInfoModal.classList.contains('is-open')) return;
                tripsDownloadInfoModal.classList.remove('is-open');
                tripsDownloadInfoModal.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('users-modal-open');
            }

            if (tripsDownloadLink) {
                tripsDownloadLink.addEventListener('click', function (event) {
                    event.preventDefault();
                    const selectedIndex = Number(tripSelector.value || 0);
                    const tripToEdit = filtered[selectedIndex] || filtered[0] || null;
                    showTripsDownloadModal(tripToEdit);
                });
            }

            if (tripsDownloadModalClose) {
                tripsDownloadModalClose.addEventListener('click', hideTripsDownloadModal);
            }

            if (tripsDownloadModalCancel) {
                tripsDownloadModalCancel.addEventListener('click', hideTripsDownloadModal);
            }

            if (tripsEditForm) {
                tripsEditForm.addEventListener('submit', async function (event) {
                    event.preventDefault();

                    const tripId = tripsEditTripId ? String(tripsEditTripId.value || '').trim() : '';
                    if (!tripId) {
                        alert('No hay un viaje válido para editar.');
                        return;
                    }

                    const payload = {
                        trip_id: tripId,
                        estado_viaje: tripsEditEstado ? String(tripsEditEstado.value || '').trim().toLowerCase() : '',
                        origen: tripsEditOrigen ? String(tripsEditOrigen.value || '').trim() : '',
                        destino: tripsEditDestino ? String(tripsEditDestino.value || '').trim() : '',
                        conductor: tripsEditConductor ? String(tripsEditConductor.value || '').trim() : '',
                        cliente: tripsEditCliente ? String(tripsEditCliente.value || '').trim() : '',
                        vehiculo_asignado: tripsEditVehiculo ? String(tripsEditVehiculo.value || '').trim() : '',
                        ubicacion_actual: tripsEditUbicacion ? String(tripsEditUbicacion.value || '').trim() : ''
                    };

                    const originalText = tripsDownloadModalConfirm ? tripsDownloadModalConfirm.textContent : 'Guardar edición';
                    if (tripsDownloadModalConfirm) {
                        tripsDownloadModalConfirm.disabled = true;
                        tripsDownloadModalConfirm.textContent = 'Guardando...';
                    }

                    try {
                        const response = await fetch('/admin/trip/update', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'Accept': 'application/json'
                            },
                            body: JSON.stringify(payload)
                        });

                        const result = await response.json();
                        if (!response.ok || !result.ok) {
                            throw new Error(result.message || 'No se pudo actualizar el viaje.');
                        }

                        hideTripsDownloadModal();
                        alert('Viaje actualizado correctamente.');
                        location.reload();
                    } catch (error) {
                        alert(error.message || 'Error al guardar la edición del viaje.');
                    } finally {
                        if (tripsDownloadModalConfirm) {
                            tripsDownloadModalConfirm.disabled = false;
                            tripsDownloadModalConfirm.textContent = originalText;
                        }
                    }
                });
            }

            if (tripsDownloadInfoModal) {
                tripsDownloadInfoModal.addEventListener('click', function (event) {
                    if (event.target && event.target.matches('[data-close-trips-download-modal="true"]')) {
                        hideTripsDownloadModal();
                    }
                });
            }

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape' && tripsDownloadInfoModal && tripsDownloadInfoModal.classList.contains('is-open')) {
                    hideTripsDownloadModal();
                }
            });

            function safeText(value) {
                if (value === null || value === undefined || String(value).trim() === '') return '-';
                return String(value).trim();
            }

            function normalizeText(value) {
                const text = safeText(value);
                if (text === '-') return '';
                return text.toLowerCase();
            }

            function normalizeStatus(value) {
                const s = normalizeText(value);
                if (s === 'pendiente') return 'programado';
                if (s === 'en curso') return 'en ruta';
                if (s === 'finalizado') return 'entregado';
                return s;
            }

            function getDriverAliases(selectedValue) {
                const selectedNorm = normalizeText(selectedValue);
                if (!selectedNorm) return [];

                const aliases = new Set([selectedNorm]);
                (Array.isArray(choferes) ? choferes : []).forEach(c => {
                    const nameNorm = normalizeText(c.name);
                    const userNorm = normalizeText(c.user);

                    if (selectedNorm === nameNorm || selectedNorm === userNorm) {
                        if (nameNorm) aliases.add(nameNorm);
                        if (userNorm) aliases.add(userNorm);
                    }
                });

                return Array.from(aliases);
            }

            function formatDate(value) {
                if (!value) return '-';
                const dt = new Date(value);
                if (Number.isNaN(dt.getTime())) return safeText(value);
                return dt.toLocaleDateString('es-MX');
            }

            function formatMoney(value) {
                if (value === null || value === undefined || String(value).trim() === '') return '-';
                const num = Number(value);
                if (!Number.isFinite(num)) return safeText(value);
                return `$${num.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
            }

            function setText(id, value) {
                const el = document.getElementById(id);
                if (el) el.textContent = safeText(value);
            }

            function setMapStatus(message) {
                if (mapStatus) mapStatus.textContent = safeText(message);
            }

            function ensureTripMap() {
                const mapNode = document.getElementById('trip-map');
                if (!mapNode) return null;
                if (typeof L === 'undefined') {
                    setMapStatus('No se pudo cargar el mapa (Leaflet no disponible).');
                    return null;
                }
                if (tripMap) return tripMap;

                tripMap = L.map(mapNode, {
                    center: mexicoCenter,
                    zoom: 5,
                    zoomControl: true,
                    maxBounds: mexicoBounds,
                    maxBoundsViscosity: 1.0
                });

                const tileSources = [
                    {
                        url: 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
                        attribution: '&copy; OpenStreetMap contributors'
                    },
                    {
                        url: 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',
                        attribution: '&copy; OpenStreetMap contributors &copy; CARTO'
                    }
                ];

                let tileSourceIndex = 0;
                const mountBaseLayer = () => {
                    if (!tripMap) return;
                    if (tripMapBaseLayer) {
                        tripMap.removeLayer(tripMapBaseLayer);
                        tripMapBaseLayer = null;
                    }

                    const source = tileSources[tileSourceIndex];
                    tripMapBaseLayer = L.tileLayer(source.url, {
                        maxZoom: 19,
                        attribution: source.attribution
                    });

                    tripMapBaseLayer.on('tileerror', function () {
                        if (tileSourceIndex < tileSources.length - 1) {
                            tileSourceIndex += 1;
                            mountBaseLayer();
                            setMapStatus('Servidor de mapa alterno activado.');
                        } else {
                            setMapStatus('No se pudo cargar el fondo del mapa. Revisa tu conexión a Internet.');
                        }
                    });

                    tripMapBaseLayer.addTo(tripMap);
                };

                mountBaseLayer();

                // Forzar recálculo de tamaño cuando el contenedor estuvo oculto o cambió de layout.
                setTimeout(() => {
                    if (tripMap) tripMap.invalidateSize();
                }, 120);

                return tripMap;
            }

            function splitStops(stopsText) {
                if (!stopsText) return [];

                const ignored = new Set(['-', 'no aplica', 'n/a', 'na', 'ninguna', 'ninguno', 'sin parada', 'sin paradas', 'null', 'undefined']);

                return String(stopsText)
                    .split(/\n|,|;|\|/)
                    .map(s => s.trim())
                    .filter(Boolean)
                    .filter(s => {
                        const normalized = s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
                        return !ignored.has(normalized);
                    });
            }

            function cleanPointQuery(value) {
                const raw = String(value || '').trim();
                if (!raw) return '';
                const normalized = raw.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
                const ignored = new Set(['-', 'no aplica', 'n/a', 'na', 'ninguna', 'ninguno', 'null', 'undefined']);
                return ignored.has(normalized) ? '' : raw;
            }

            function buildLocationPoints(trip) {
                if (!trip) return [];
                const rawPoints = [];

                const origen = cleanPointQuery(trip.origen);
                const ubicacionActual = cleanPointQuery(trip.ubicacion_actual);
                const destino = cleanPointQuery(trip.destino);

                if (origen) rawPoints.push({ label: 'Origen', query: origen });
                splitStops(trip.paradas).forEach((p, idx) => {
                    rawPoints.push({ label: `Parada ${idx + 1}`, query: p });
                });
                if (ubicacionActual) rawPoints.push({ label: 'Ubicacion actual', query: ubicacionActual });
                if (destino) rawPoints.push({ label: 'Destino', query: destino });

                const seen = new Set();
                return rawPoints.filter(item => {
                    const key = String(item.query || '').trim();
                    if (!key || key === '-') return false;
                    const norm = key.toLowerCase();
                    if (seen.has(norm)) return false;
                    seen.add(norm);
                    return true;
                });
            }

            function parseCoordinateQuery(query) {
                const text = String(query || '').trim();
                const match = text.match(/^(-?\d+(?:\.\d+)?)\s*,\s*(-?\d+(?:\.\d+)?)$/);
                if (!match) return null;

                const lat = Number(match[1]);
                const lng = Number(match[2]);
                if (!Number.isFinite(lat) || !Number.isFinite(lng)) return null;
                if (lat < -90 || lat > 90 || lng < -180 || lng > 180) return null;

                return { lat, lng };
            }

            async function geocodeLocation(query) {
                const key = String(query || '').trim();
                if (!key || key === '-') return null;
                if (Object.prototype.hasOwnProperty.call(geocodeCache, key)) {
                    return geocodeCache[key];
                }

                const coords = parseCoordinateQuery(key);
                if (coords) {
                    geocodeCache[key] = {
                        lat: coords.lat,
                        lng: coords.lng,
                        display: `Coordenadas ${coords.lat.toFixed(6)}, ${coords.lng.toFixed(6)}`
                    };
                    return geocodeCache[key];
                }

                try {
                    const url = `https://nominatim.openstreetmap.org/search?format=json&limit=1&countrycodes=mx&q=${encodeURIComponent(key)}`;
                    const response = await fetch(url, {
                        headers: {
                            'Accept': 'application/json'
                        }
                    });
                    if (!response.ok) {
                        geocodeCache[key] = null;
                        return null;
                    }

                    const data = await response.json();
                    const first = Array.isArray(data) ? data[0] : null;
                    if (!first || !first.lat || !first.lon) {
                        geocodeCache[key] = null;
                        return null;
                    }

                    geocodeCache[key] = {
                        lat: Number(first.lat),
                        lng: Number(first.lon),
                        display: first.display_name || key
                    };
                    return geocodeCache[key];
                } catch (error) {
                    geocodeCache[key] = null;
                    return null;
                }
            }

            async function renderTripMap(trip) {
                const map = ensureTripMap();
                if (!map) return;

                setTimeout(() => {
                    if (tripMap) tripMap.invalidateSize();
                }, 80);

                if (tripMapLayer) {
                    map.removeLayer(tripMapLayer);
                    tripMapLayer = null;
                }

                tripMapLayer = L.layerGroup().addTo(map);

                if (!trip) {
                    setMapStatus('Selecciona un viaje para visualizar la ruta estimada.');
                    map.setView(mexicoCenter, 5);
                    return;
                }

                const points = buildLocationPoints(trip);
                if (points.length === 0) {
                    setMapStatus('Este viaje no tiene ubicaciones suficientes para mostrar en mapa.');
                    map.setView(mexicoCenter, 5);
                    return;
                }

                setMapStatus('Cargando ubicaciones del viaje en el mapa...');

                const resolved = await Promise.all(points.map(async p => {
                    const geo = await geocodeLocation(p.query);
                    return geo ? { ...p, ...geo } : null;
                }));

                const validPoints = resolved.filter(Boolean);
                if (validPoints.length === 0) {
                    setMapStatus('No se pudieron ubicar las direcciones del viaje en el mapa.');
                    map.setView(mexicoCenter, 5);
                    return;
                }

                const latLngs = validPoints.map(p => [p.lat, p.lng]);

                function getPointStyle(label) {
                    const text = String(label || '').toLowerCase();
                    if (text.startsWith('origen')) {
                        return { color: '#16a34a', fillColor: '#22c55e', text: 'Origen' };
                    }
                    if (text.startsWith('ubicacion actual') || text.startsWith('ubicaci\u00f3n actual')) {
                        return { color: '#ca8a04', fillColor: '#facc15', text: 'Ubicacion actual' };
                    }
                    if (text.startsWith('destino')) {
                        return { color: '#dc2626', fillColor: '#ef4444', text: 'Destino' };
                    }
                    if (text.startsWith('parada')) {
                        return { color: '#2563eb', fillColor: '#3b82f6', text: 'Parada' };
                    }
                    return { color: '#0ea5e9', fillColor: '#38bdf8', text: String(label || 'Punto') };
                }

                validPoints.forEach((point) => {
                    const style = getPointStyle(point.label);
                    const marker = L.circleMarker([point.lat, point.lng], {
                        radius: 8,
                        color: style.color,
                        weight: 2,
                        fillColor: style.fillColor,
                        fillOpacity: 0.95
                    }).addTo(tripMapLayer);
                    marker.bindPopup(`<strong>${point.label}</strong><br>${point.query}<br><small>${point.display}</small>`);
                    marker.bindTooltip(style.text, {
                        permanent: true,
                        direction: 'top',
                        className: 'trip-point-label',
                        offset: [0, -10]
                    });
                });

                if (latLngs.length > 1) {
                    L.polyline(latLngs, { color: '#38bdf8', weight: 4, opacity: 0.9 }).addTo(tripMapLayer);
                    map.fitBounds(latLngs, { padding: [25, 25] });
                } else {
                    map.setView(latLngs[0], 12);
                }

                const unresolved = points.length - validPoints.length;
                if (unresolved > 0) {
                    setMapStatus(`Ruta cargada parcialmente. ${unresolved} ubicacion(es) no pudieron geocodificarse.`);
                } else {
                    setMapStatus('Ruta cargada correctamente.');
                }
            }

            const tripSectionDefs = {
                ruta: {
                    title: 'Origen y destino',
                    fields: [
                        { label: 'Lugar de origen', key: 'origen' },
                        { label: 'Lugar de destino', key: 'destino' },
                        { label: 'Direccion de carga', key: 'direccion_carga' },
                        { label: 'Direccion de entrega', key: 'direccion_entrega' },
                        { label: 'Distancia estimada', key: 'distancia_estimada' },
                        { label: 'Tiempo estimado', key: 'tiempo_estimado' }
                    ]
                },
                vehiculo: {
                    title: 'Vehiculo y conductor',
                    fields: [
                        { label: 'Vehiculo asignado', key: 'vehiculo_asignado' },
                        { label: 'Conductor', key: 'conductor' },
                        { label: 'Ayudante', key: 'ayudante' },
                        { label: 'Capacidad utilizada', key: 'capacidad_utilizada' }
                    ]
                },
                carga: {
                    title: 'Informacion de la carga',
                    fields: [
                        { label: 'Tipo de mercancia', key: 'tipo_mercancia' },
                        { label: 'Peso', key: 'peso' },
                        { label: 'Volumen', key: 'volumen' },
                        { label: 'Paquetes', key: 'cantidad_paquetes' },
                        { label: 'Valor de mercancia', key: 'valor_mercancia', type: 'money' },
                        { label: 'Cliente', key: 'cliente' }
                    ]
                },
                operativo: {
                    title: 'Control operativo',
                    fields: [
                        { label: 'Hora de salida', key: 'hora_salida' },
                        { label: 'Hora de llegada', key: 'hora_llegada' },
                        { label: 'Ubicacion actual', key: 'ubicacion_actual' },
                        { label: 'Paradas', key: 'paradas' },
                        { label: 'Incidentes', key: 'incidentes' },
                        { label: 'Observaciones', key: 'observaciones' }
                    ]
                },
                costos: {
                    title: 'Costos del viaje',
                    fields: [
                        { label: 'Combustible', key: 'combustible', type: 'money' },
                        { label: 'Peajes', key: 'peajes', type: 'money' },
                        { label: 'Viaticos', key: 'viaticos', type: 'money' },
                        { label: 'Costo total', key: 'costo_total', type: 'money' },
                        { label: 'Ganancia', key: 'ganancia', type: 'money' }
                    ]
                },
                documentos: {
                    title: 'Documentos del viaje',
                    fields: [
                        { label: 'Orden de transporte', key: 'orden_transporte' },
                        { label: 'Factura', key: 'factura' },
                        { label: 'Carta porte', key: 'carta_porte' },
                        { label: 'Comprobante de entrega', key: 'comprobante_entrega' },
                        { label: 'Firma del cliente', key: 'firma_cliente' }
                    ]
                },
                estado: {
                    title: 'Estado del viaje',
                    fields: [
                        { label: 'Estado actual', key: 'estado_viaje' },
                        { label: 'Fecha de salida', key: 'fecha_salida', type: 'date' },
                        { label: 'Llegada estimada', key: 'fecha_llegada_estimada', type: 'date' },
                        { label: 'ID de viaje', key: 'trip_id' }
                    ]
                }
            };

            function buildTripRows(sectionKey, trip) {
                const section = tripSectionDefs[sectionKey];
                if (!section || !trip) return [];
                return section.fields.map(field => {
                    const raw = trip[field.key];
                    let value = safeText(raw);
                    if (field.type === 'date') value = formatDate(raw);
                    if (field.type === 'money') value = formatMoney(raw);
                    return [field.label, value];
                });
            }

            function openTripSectionPdf(sectionKey) {
                if (!selectedTrip) {
                    alert('Selecciona un viaje para ver su PDF.');
                    return;
                }

                const section = tripSectionDefs[sectionKey];
                if (!section) return;

                if (!window.jspdf || !window.jspdf.jsPDF) {
                    alert('No se pudo cargar la libreria PDF.');
                    return;
                }

                const { jsPDF } = window.jspdf;
                const doc = new jsPDF();
                const rows = buildTripRows(sectionKey, selectedTrip);

                doc.setFontSize(14);
                doc.text(`Viaje - ${section.title}`, 14, 15);
                doc.setFontSize(10);
                doc.text(`Generado: ${new Date().toLocaleString('es-MX')}`, 14, 21);
                doc.text(`ID: ${safeText(selectedTrip.trip_id)} | Conductor: ${safeText(selectedTrip.conductor)}`, 14, 27);

                if (typeof doc.autoTable === 'function') {
                    doc.autoTable({
                        head: [['Campo', 'Valor']],
                        body: rows,
                        startY: 32,
                        styles: { fontSize: 10 }
                    });
                } else {
                    let y = 34;
                    rows.forEach(([field, value]) => {
                        doc.text(`${field}: ${value}`, 14, y);
                        y += 6;
                    });
                }

                const pdfUrl = doc.output('bloburl');
                window.open(pdfUrl, '_blank');
            }

            function getStatusClass(status) {
                const s = String(status || '').toLowerCase();
                if (s === 'programado' || s === 'pendiente') return 'status-programado';
                if (s === 'en carga') return 'status-carga';
                if (s === 'en ruta' || s === 'en curso') return 'status-ruta';
                if (s === 'entregado' || s === 'finalizado') return 'status-entregado';
                if (s === 'cancelado') return 'status-cancelado';
                return '';
            }

            const statusOptions = Array.from(new Set(trips.map(t => safeText(t.estado_viaje)).filter(v => v !== '-'))).sort();
            const driversFromTrips = trips.map(t => safeText(t.conductor)).filter(v => v !== '-');
            const driversFromUsers = (Array.isArray(choferes) ? choferes : [])
                .map(c => safeText(c.name || c.user))
                .filter(v => v !== '-');
            const driverOptions = Array.from(new Set([...driversFromUsers, ...driversFromTrips])).sort();
            const clientOptions = Array.from(new Set(trips.map(t => safeText(t.cliente)).filter(v => v !== '-'))).sort();

            statusFilter.innerHTML = '<option value="">Todos los estados</option>' + statusOptions.map(s => `<option value="${s}">${s}</option>`).join('');
            clientFilter.innerHTML = '<option value="">Todos los clientes</option>' + clientOptions.map(c => `<option value="${c}">${c}</option>`).join('');
            driverFilter.innerHTML = '<option value="">Todos los conductores</option>' + driverOptions.map(d => `<option value="${d}">${d}</option>`).join('');

            if (assignDriverSelector) {
                assignDriverSelector.innerHTML = '<option value="">Selecciona chofer</option>' + driverOptions.map(d => `<option value="${d}">${d}</option>`).join('');
            }

            let filtered = [...trips];

            function setAssignFeedback(message, isError) {
                if (!assignTripFeedback) return;
                assignTripFeedback.textContent = safeText(message);
                assignTripFeedback.style.color = isError ? '#fecaca' : '#bbf7d0';
            }

            function findTripById(tripId) {
                const id = String(tripId || '').trim();
                if (!id) return null;
                return trips.find(t => String(t.trip_id || '').trim() === id) || null;
            }

            function getVehicleOptionsForDriver(driverName) {
                const aliases = getDriverAliases(driverName);
                if (aliases.length === 0) {
                    const allVehicles = Array.from(new Set((Array.isArray(vehicles) ? vehicles : [])
                        .map(v => safeText(v.placas || v.numero_unidad))
                        .filter(v => v !== '-')));
                    return allVehicles;
                }

                const linked = (Array.isArray(vehicles) ? vehicles : [])
                    .filter(v => aliases.includes(normalizeText(v.conductor_asignado)))
                    .map(v => safeText(v.placas || v.numero_unidad))
                    .filter(v => v !== '-');

                const uniqueLinked = Array.from(new Set(linked));
                if (uniqueLinked.length > 0) return uniqueLinked;

                return Array.from(new Set((Array.isArray(vehicles) ? vehicles : [])
                    .map(v => safeText(v.placas || v.numero_unidad))
                    .filter(v => v !== '-')));
            }

            function refreshAssignVehicleOptions() {
                if (!assignVehicleSelector) return;
                const driverValue = assignDriverSelector ? assignDriverSelector.value : '';
                const options = getVehicleOptionsForDriver(driverValue);
                assignVehicleSelector.innerHTML = '<option value="">Sin vehículo / manual</option>' + options.map(v => `<option value="${v}">${v}</option>`).join('');

                const tripValue = assignTripSelector ? assignTripSelector.value : '';
                const trip = findTripById(tripValue);
                if (trip) {
                    const currentVehicle = safeText(trip.vehiculo_asignado);
                    if (currentVehicle !== '-') {
                        const hasOption = Array.from(assignVehicleSelector.options).some(opt => String(opt.value || '') === currentVehicle);
                        if (!hasOption) {
                            const extra = document.createElement('option');
                            extra.value = currentVehicle;
                            extra.textContent = currentVehicle;
                            assignVehicleSelector.appendChild(extra);
                        }
                        assignVehicleSelector.value = currentVehicle;
                    }
                }
            }

            function refreshAssignTripOptions(selectedTripId) {
                if (!assignTripSelector) return;
                const keep = String(selectedTripId || assignTripSelector.value || '').trim();
                assignTripSelector.innerHTML = '<option value="">Selecciona viaje</option>' + filtered.map(t => {
                    const tripId = safeText(t.trip_id);
                    const client = safeText(t.cliente);
                    const route = `${safeText(t.origen)} -> ${safeText(t.destino)}`;
                    return `<option value="${tripId}">${tripId} | ${client} | ${route}</option>`;
                }).join('');

                if (keep) {
                    const exists = Array.from(assignTripSelector.options).some(opt => String(opt.value || '') === keep);
                    if (exists) assignTripSelector.value = keep;
                }
            }

            function renderTripOptions() {
                if (filtered.length === 0) {
                    tripSelector.innerHTML = '<option value="">Sin viajes</option>';
                    return;
                }
                tripSelector.innerHTML = filtered.map((t, i) => `<option value="${i}">${safeText(t.trip_id)} - ${safeText(t.origen)} -> ${safeText(t.destino)}</option>`).join('');
            }

            function renderTripTable(selectedIndex) {
                if (filtered.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="8">No hay viajes disponibles con ese filtro.</td></tr>';
                    return;
                }

                tableBody.innerHTML = filtered.map((t, i) => `
                    <tr data-index="${i}" class="${i === selectedIndex ? 'selected-trip-row' : ''}">
                        <td>${safeText(t.trip_id)}</td>
                        <td>${formatDate(t.fecha_salida)}</td>
                        <td><span class="trip-chip ${getStatusClass(t.estado_viaje)}">${safeText(t.estado_viaje)}</span></td>
                        <td>${safeText(t.cliente)}</td>
                        <td>${safeText(t.tipo_viaje)}</td>
                        <td>${safeText(t.origen)}</td>
                        <td>${safeText(t.destino)}</td>
                        <td>
                            <button type="button" class="btn secondary trip-edit-btn" data-index="${i}">Editar</button>
                            <button type="button" class="btn danger trip-delete-btn" data-index="${i}">Eliminar</button>
                        </td>
                    </tr>
                `).join('');
            }

            async function deleteTripByIndex(index) {
                const trip = filtered[index];
                if (!trip) return;
                const tripId = safeText(trip.trip_id);
                if (tripId === '-') return;

                const ok = confirm(`¿Seguro que deseas eliminar el viaje ${tripId}? Esta acción no se puede deshacer.`);
                if (!ok) return;

                try {
                    const response = await fetch('/admin/trip/delete', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({ trip_id: tripId })
                    });

                    const result = await response.json();
                    if (!response.ok || !result.ok) {
                        alert(result.message || 'No se pudo eliminar el viaje.');
                        return;
                    }

                    alert('Viaje eliminado correctamente.');
                    location.reload();
                } catch (error) {
                    alert('Error de red al eliminar viaje.');
                }
            }

            async function editTripByIndex(index) {
                const trip = filtered[index];
                if (!trip) return;
                showTripsDownloadModal(trip);
            }

            function fillTripPanels(trip) {
                selectedTrip = trip || null;
                if (!trip) {
                    [
                        't-origen', 't-destino', 't-direccion-carga', 't-direccion-entrega', 't-distancia', 't-tiempo-estimado',
                        't-vehiculo', 't-conductor', 't-ayudante', 't-capacidad-utilizada', 't-mercancia', 't-peso', 't-volumen',
                        't-paquetes', 't-valor-mercancia', 't-cliente', 't-hora-salida', 't-hora-llegada', 't-ubicacion',
                        't-paradas', 't-incidentes', 't-observaciones', 't-combustible', 't-peajes', 't-viaticos',
                        't-costo-total', 't-ganancia', 't-orden', 't-factura', 't-carta-porte', 't-comprobante',
                        't-firma', 't-fecha-salida', 't-fecha-llegada', 't-trip-id'
                    ].forEach(id => setText(id, '-'));
                    if (estadoActual) {
                        estadoActual.textContent = '-';
                        estadoActual.className = 'trip-chip';
                    }
                    renderTripMap(null);
                    return;
                }

                setText('t-origen', trip.origen);
                setText('t-destino', trip.destino);
                setText('t-direccion-carga', trip.direccion_carga);
                setText('t-direccion-entrega', trip.direccion_entrega);
                setText('t-distancia', trip.distancia_estimada);
                setText('t-tiempo-estimado', trip.tiempo_estimado);
                setText('t-vehiculo', trip.vehiculo_asignado);
                setText('t-conductor', trip.conductor);
                setText('t-ayudante', trip.ayudante);
                setText('t-capacidad-utilizada', trip.capacidad_utilizada);
                setText('t-mercancia', trip.tipo_mercancia);
                setText('t-peso', trip.peso);
                setText('t-volumen', trip.volumen);
                setText('t-paquetes', trip.cantidad_paquetes);
                setText('t-valor-mercancia', formatMoney(trip.valor_mercancia));
                setText('t-cliente', trip.cliente);
                setText('t-hora-salida', trip.hora_salida);
                setText('t-hora-llegada', trip.hora_llegada);
                setText('t-ubicacion', trip.ubicacion_actual);
                setText('t-paradas', trip.paradas);
                setText('t-incidentes', trip.incidentes);
                setText('t-observaciones', trip.observaciones);
                setText('t-combustible', formatMoney(trip.combustible));
                setText('t-peajes', formatMoney(trip.peajes));
                setText('t-viaticos', formatMoney(trip.viaticos));
                setText('t-costo-total', formatMoney(trip.costo_total));
                setText('t-ganancia', formatMoney(trip.ganancia));
                setText('t-orden', trip.orden_transporte);
                setText('t-factura', trip.factura);
                setText('t-carta-porte', trip.carta_porte);
                setText('t-comprobante', trip.comprobante_entrega);
                setText('t-firma', trip.firma_cliente);
                setText('t-fecha-salida', formatDate(trip.fecha_salida));
                setText('t-fecha-llegada', formatDate(trip.fecha_llegada_estimada));
                setText('t-trip-id', trip.trip_id);

                if (estadoActual) {
                    estadoActual.textContent = safeText(trip.estado_viaje);
                    estadoActual.className = `trip-chip ${getStatusClass(trip.estado_viaje)}`;
                }

                renderTripMap(trip);
            }

            function refreshTripsView() {
                const status = statusFilter.value;
                const client = clientFilter.value;
                const driver = driverFilter.value;
                const normalizedStatus = normalizeStatus(status);
                const normalizedClient = normalizeText(client);
                const driverAliases = getDriverAliases(driver);

                filtered = trips.filter(t => {
                    const okStatus = !normalizedStatus || normalizeStatus(t.estado_viaje) === normalizedStatus;
                    const okClient = !normalizedClient || normalizeText(t.cliente) === normalizedClient;
                    const okDriver = driverAliases.length === 0 || driverAliases.includes(normalizeText(t.conductor));
                    return okStatus && okClient && okDriver;
                });

                renderTripOptions();
                const noData = filtered.length === 0;
                tripEmpty.style.display = noData ? 'block' : 'none';

                const idx = noData ? -1 : 0;
                if (!noData) tripSelector.value = '0';
                renderTripTable(idx);
                fillTripPanels(noData ? null : filtered[0]);

                const selectedTripId = noData ? '' : safeText(filtered[0].trip_id);
                refreshAssignTripOptions(selectedTripId);
                if (assignDriverSelector && !assignDriverSelector.value && !noData) {
                    const firstDriver = safeText(filtered[0].conductor);
                    if (firstDriver !== '-') assignDriverSelector.value = firstDriver;
                }
                refreshAssignVehicleOptions();
            }

            statusFilter.addEventListener('change', refreshTripsView);
            clientFilter.addEventListener('change', refreshTripsView);
            driverFilter.addEventListener('change', refreshTripsView);
            tripSelector.addEventListener('change', function () {
                const idx = Number(this.value);
                renderTripTable(idx);
                fillTripPanels(filtered[idx]);
                if (assignTripSelector && filtered[idx]) {
                    assignTripSelector.value = safeText(filtered[idx].trip_id);
                    refreshAssignVehicleOptions();
                }
            });

            if (assignDriverSelector) {
                assignDriverSelector.addEventListener('change', refreshAssignVehicleOptions);
            }

            if (assignTripSelector) {
                assignTripSelector.addEventListener('change', function () {
                    const trip = findTripById(this.value);
                    if (!trip) {
                        refreshAssignVehicleOptions();
                        return;
                    }

                    if (assignDriverSelector) {
                        const currentDriver = safeText(trip.conductor);
                        if (currentDriver !== '-') {
                            const hasDriver = Array.from(assignDriverSelector.options).some(opt => String(opt.value || '') === currentDriver);
                            if (!hasDriver) {
                                const extraDriver = document.createElement('option');
                                extraDriver.value = currentDriver;
                                extraDriver.textContent = currentDriver;
                                assignDriverSelector.appendChild(extraDriver);
                            }
                            assignDriverSelector.value = currentDriver;
                        }
                    }

                    refreshAssignVehicleOptions();
                });
            }

            if (assignTripButton) {
                assignTripButton.addEventListener('click', async function () {
                    const tripId = assignTripSelector ? String(assignTripSelector.value || '').trim() : '';
                    const conductor = assignDriverSelector ? String(assignDriverSelector.value || '').trim() : '';
                    const vehiculo = assignVehicleSelector ? String(assignVehicleSelector.value || '').trim() : '';

                    if (!tripId) {
                        setAssignFeedback('Selecciona un viaje para asignar.', true);
                        return;
                    }

                    if (!conductor) {
                        setAssignFeedback('Selecciona un chofer antes de guardar.', true);
                        return;
                    }

                    const trip = findTripById(tripId);
                    const payload = {
                        trip_id: tripId,
                        conductor,
                        vehiculo_asignado: vehiculo,
                        cliente: trip ? safeText(trip.cliente) : ''
                    };

                    assignTripButton.disabled = true;
                    const originalText = assignTripButton.textContent;
                    assignTripButton.textContent = 'Guardando...';
                    setAssignFeedback('Guardando asignación...', false);

                    try {
                        const response = await fetch('/admin/trip/update', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'Accept': 'application/json'
                            },
                            body: JSON.stringify(payload)
                        });

                        const result = await response.json();
                        if (!response.ok || !result.ok) {
                            setAssignFeedback(result.message || 'No se pudo guardar la asignación.', true);
                            return;
                        }

                        setAssignFeedback('Asignación guardada correctamente.', false);
                        setTimeout(() => location.reload(), 500);
                    } catch (error) {
                        setAssignFeedback('Error de red al guardar la asignación.', true);
                    } finally {
                        assignTripButton.disabled = false;
                        assignTripButton.textContent = originalText;
                    }
                });
            }

            tableBody.addEventListener('click', function (event) {
                const editBtn = event.target.closest('.trip-edit-btn');
                if (editBtn) {
                    const idxEdit = Number(editBtn.dataset.index);
                    editTripByIndex(idxEdit);
                    return;
                }

                const deleteBtn = event.target.closest('.trip-delete-btn');
                if (deleteBtn) {
                    const idxDelete = Number(deleteBtn.dataset.index);
                    deleteTripByIndex(idxDelete);
                    return;
                }

                const row = event.target.closest('tr[data-index]');
                if (!row) return;
                const idx = Number(row.dataset.index);
                tripSelector.value = String(idx);
                renderTripTable(idx);
                fillTripPanels(filtered[idx]);
                if (assignTripSelector && filtered[idx]) {
                    assignTripSelector.value = safeText(filtered[idx].trip_id);
                }
                if (assignDriverSelector && filtered[idx]) {
                    const currentDriver = safeText(filtered[idx].conductor);
                    if (currentDriver !== '-') {
                        const hasDriver = Array.from(assignDriverSelector.options).some(opt => String(opt.value || '') === currentDriver);
                        if (!hasDriver) {
                            const extraDriver = document.createElement('option');
                            extraDriver.value = currentDriver;
                            extraDriver.textContent = currentDriver;
                            assignDriverSelector.appendChild(extraDriver);
                        }
                        assignDriverSelector.value = currentDriver;
                    }
                }
                refreshAssignVehicleOptions();
            });

            tripSectionButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    const sectionKey = this.dataset.section;
                    openTripSectionPdf(sectionKey);
                });
            });

            // Evita quedar atrapado en un estado preseleccionado por el navegador.
            statusFilter.value = '';
            clientFilter.value = '';
            driverFilter.value = '';

            // Inicializa el mapa base aunque aún no exista viaje seleccionado.
            ensureTripMap();
            window.adminRefreshTripMap = function () {
                if (tripMap) tripMap.invalidateSize();
            };
            setMapStatus('Selecciona un viaje para visualizar la ruta estimada.');

            refreshTripsView();
        }
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const origenInput = document.getElementById('cotizacion-origen');
            const destinoInput = document.getElementById('cotizacion-destino');
            const distanciaInput = document.getElementById('cotizacion-distancia');
            const precioLitroInput = document.getElementById('cotizacion-precio-litro');
            const rendimientoInput = document.getElementById('cotizacion-rendimiento');
            const costoServicioInput = document.getElementById('cotizacion-costo-servicio');
            const litrosOutput = document.getElementById('cotizacion-litros');
            const costoGasolinaOutput = document.getElementById('cotizacion-costo-gasolina');
            const totalOutput = document.getElementById('cotizacion-total');
            const summaryDistancia = document.getElementById('cotizacion-summary-distancia');
            const summaryLitros = document.getElementById('cotizacion-summary-litros');
            const summarySubtotal = document.getElementById('cotizacion-summary-subtotal');
            const summaryCostoServicio = document.getElementById('cotizacion-summary-costo-servicio');
            const summaryTotal = document.getElementById('cotizacion-summary-total');
            const calcBtn = document.getElementById('cotizacion-calc-btn');
            const distanceBtn = document.getElementById('cotizacion-distance-btn');

            async function geocodeAddress(address) {
                const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}&limit=1`;
                const response = await fetch(url, {
                    headers: {
                        'Accept': 'application/json'
                    }
                });
                const data = await response.json();
                if (!Array.isArray(data) || data.length === 0) return null;
                return {
                    lat: parseFloat(data[0].lat),
                    lon: parseFloat(data[0].lon)
                };
            }

            function calculateHaversineDistance(coord1, coord2) {
                const toRadians = degrees => degrees * Math.PI / 180;
                const R = 6371;
                const dLat = toRadians(coord2.lat - coord1.lat);
                const dLon = toRadians(coord2.lon - coord1.lon);
                const lat1 = toRadians(coord1.lat);
                const lat2 = toRadians(coord2.lat);
                const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) + Math.sin(dLon / 2) * Math.sin(dLon / 2) * Math.cos(lat1) * Math.cos(lat2);
                const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
                return R * c;
            }

            async function calculateDistanceFromAddresses() {
                const origen = origenInput.value.trim();
                const destino = destinoInput.value.trim();

                if (!origen || !destino) {
                    alert('Ingresa origen y destino para calcular la distancia.');
                    return;
                }

                const origenCoords = await geocodeAddress(origen);
                const destinoCoords = await geocodeAddress(destino);

                if (!origenCoords || !destinoCoords) {
                    alert('No se encontró la dirección. Verifica origen y destino.');
                    return;
                }

                let distanciaKm = 0;
                try {
                    const routeUrl = `https://router.project-osrm.org/route/v1/driving/${origenCoords.lon},${origenCoords.lat};${destinoCoords.lon},${destinoCoords.lat}?overview=false`;
                    const routeResponse = await fetch(routeUrl);
                    const routeData = await routeResponse.json();

                    if (routeData && routeData.routes && routeData.routes[0] && routeData.routes[0].distance) {
                        distanciaKm = routeData.routes[0].distance / 1000;
                    } else {
                        distanciaKm = calculateHaversineDistance(origenCoords, destinoCoords);
                    }
                } catch (error) {
                    distanciaKm = calculateHaversineDistance(origenCoords, destinoCoords);
                }

                distanciaInput.value = distanciaKm.toFixed(1);
                summaryDistancia.textContent = `${distanciaKm.toFixed(1)} km`;
                calcularCotizacion();
            }

            function formatMoney(value) {
                return `$${value.toFixed(2)}`;
            }

            function calcularCotizacion() {
                const distancia = parseFloat(distanciaInput.value) || 0;
                const precioLitro = parseFloat(precioLitroInput.value) || 0;
                const rendimiento = parseFloat(rendimientoInput.value) || 0;
                const costoServicio = parseFloat(costoServicioInput.value) || 0;

                if (distancia === 0) {
                    summaryDistancia.textContent = '0 km';
                    summaryLitros.textContent = '0.00';
                    summarySubtotal.textContent = '$0.00';
                    summaryCostoServicio.textContent = `$${costoServicio.toFixed(2)}`;
                    summaryTotal.textContent = formatMoney(costoServicio);
                    litrosOutput.value = '';
                    costoGasolinaOutput.value = '';
                    totalOutput.value = costoServicio > 0 ? costoServicio.toFixed(2) : '';
                    return;
                }

                if (rendimiento <= 0) {
                    alert('Ingresa un rendimiento válido mayor que cero.');
                    return;
                }

                const litros = distancia / rendimiento;
                const costoGasolina = litros * precioLitro;
                const totalFinal = costoGasolina + costoServicio;

                litrosOutput.value = litros.toFixed(2);
                costoGasolinaOutput.value = costoGasolina.toFixed(2);
                totalOutput.value = totalFinal.toFixed(2);
                summaryDistancia.textContent = `${distancia.toFixed(1)} km`;
                summaryLitros.textContent = litros.toFixed(2);
                summarySubtotal.textContent = formatMoney(costoGasolina);
                summaryCostoServicio.textContent = formatMoney(costoServicio);
                summaryTotal.textContent = formatMoney(totalFinal);
            }

            if (distanceBtn) {
                distanceBtn.addEventListener('click', calculateDistanceFromAddresses);
            }
            if (calcBtn) {
                calcBtn.addEventListener('click', calcularCotizacion);
            }

            [distanciaInput, precioLitroInput, rendimientoInput, costoServicioInput].forEach(function (input) {
                if (!input) return;
                input.addEventListener('input', calcularCotizacion);
            });
        });
    </script>



