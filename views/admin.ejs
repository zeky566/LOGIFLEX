        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
    <script id="vehicles-data" type="application/json"><%- JSON.stringify(Array.isArray(dbVehiculos) ? dbVehiculos : []) %></script>
    <script id="trips-data" type="application/json"><%- JSON.stringify(Array.isArray(dbViajes) ? dbViajes : []) %></script>
    <script id="choferes-data" type="application/json"><%- JSON.stringify(Array.isArray(dbChoferes) ? dbChoferes : []) %></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initAdminDashboard();
            console.log('Administrador conectado: <%= name %>');
            try {
                initVehiclesModule();
            } catch (error) {
                console.error('Error al iniciar módulo de vehículos:', error);
            }

            try {
                initTripsModule();
            } catch (error) {
                console.error('Error al iniciar módulo de viajes:', error);
                const mapStatus = document.getElementById('trip-map-status');
                if (mapStatus) mapStatus.textContent = 'No se pudo iniciar el módulo de mapa.';
            }
        });

        function readJsonData(scriptId) {
            const node = document.getElementById(scriptId);
            if (!node) return [];
            try {
                return JSON.parse(node.textContent || '[]');
            } catch (error) {
                console.error('No se pudo leer JSON embebido:', scriptId, error);
                return [];
            }
        }

        function initAdminDashboard() {
            const sidebar = document.getElementById('admin-dashboard-sidebar');
            const toggle = document.getElementById('admin-dashboard-toggle');
            const main = document.querySelector('.admin-dashboard-main');
            const links = Array.from(document.querySelectorAll('.admin-dashboard-link[data-panel-target]'));
            const navGroups = Array.from(document.querySelectorAll('.admin-nav-group[data-panel-target]'));
            const submenuLinks = Array.from(document.querySelectorAll('.admin-dashboard-submenu-link[data-panel-target]'));
            const panels = Array.from(document.querySelectorAll('.admin-dashboard-panel'));
            const usersAddButton = document.getElementById('users-inline-add');
            const usersSaveButton = document.getElementById('users-inline-save');
            const vehiclesAddButton = document.getElementById('vehicles-inline-add');
            const vehiclesSaveButton = document.getElementById('vehicles-inline-save');
            const tripsDownload = document.getElementById('trips-excel-download');
            const tripsUpload = document.getElementById('trips-excel-upload');

            if (!links.length || !panels.length) return;

            // Corrige paneles fuera del contenedor principal para evitar que se rendericen debajo del sidebar.
            if (main) {
                panels.forEach(function (panel) {
                    if (panel.parentElement !== main) {
                        main.appendChild(panel);
                    }
                });
            }

            function showPanel(panelId) {
                panels.forEach(function (panel) {
                    panel.classList.toggle('is-active-panel', panel.id === panelId);
                });

                links.forEach(function (link) {
                    const isActive = link.dataset.panelTarget === panelId;
                    link.classList.toggle('is-active', isActive);
                    link.setAttribute('aria-pressed', isActive ? 'true' : 'false');
                });

                navGroups.forEach(function (group) {
                    const isGroupActive = group.dataset.panelTarget === panelId;
                    group.classList.toggle('is-open', isGroupActive);
                });

                if (sidebar) sidebar.classList.remove('is-open');

                if (panelId === 'admin-panel-viajes' && typeof window.adminRefreshTripMap === 'function') {
                    window.setTimeout(function () {
                        window.adminRefreshTripMap();
                    }, 180);
                }
            }

            links.forEach(function (link) {
                link.addEventListener('click', function () {
                    const panelId = link.dataset.panelTarget || 'admin-panel-resumen';
                    const group = link.closest('.admin-nav-group');
                    const hadOpenState = group ? group.classList.contains('is-open') : false;

                    showPanel(panelId);

                    if (group && hadOpenState) {
                        group.classList.toggle('is-open');
                    }
                });
            });

            submenuLinks.forEach(function (subLink) {
                subLink.addEventListener('click', function (event) {
                    event.stopPropagation();
                    const panelId = subLink.dataset.panelTarget || 'admin-panel-resumen';
                    const scrollTarget = subLink.dataset.scrollTarget || '';
                    const action = subLink.dataset.action || '';
                    showPanel(panelId);

                    if (scrollTarget) {
                        window.setTimeout(function () {
                            const target = document.querySelector(scrollTarget);
                            if (target && typeof target.scrollIntoView === 'function') {
                                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                            }
                        }, 120);
                    }

                    if (action) {
                        window.setTimeout(function () {
                            if (action === 'users-add' && usersAddButton) usersAddButton.click();
                            if (action === 'users-save' && usersSaveButton) usersSaveButton.click();
                            if (action === 'vehicles-add' && vehiclesAddButton) vehiclesAddButton.click();
                            if (action === 'vehicles-save' && vehiclesSaveButton) vehiclesSaveButton.click();
                            if (action === 'trips-download' && tripsDownload) tripsDownload.click();
                            if (action === 'trips-upload' && tripsUpload) tripsUpload.click();
                        }, 120);
                    }
                });
            });

            if (toggle && sidebar) {
                toggle.addEventListener('click', function () {
                    sidebar.classList.toggle('is-open');
                });
            }

            window.showAdminDashboardPanel = showPanel;
        }

        function initVehiclesModule() {
            const vehicles = readJsonData('vehicles-data');
            const choferes = readJsonData('choferes-data');
            const driverFilter = document.getElementById('vehicle-driver-filter');
            const vehicleSelector = document.getElementById('vehicle-selector');
            const tableBody = document.getElementById('vehicles-summary-body');
            const vehicleEmpty = document.getElementById('vehicle-empty');
            const sectionButtons = document.querySelectorAll('.vehicle-pdf-btn');
            const addVehicleButton = document.getElementById('vehicles-inline-add');
            const saveVehiclesButton = document.getElementById('vehicles-inline-save');
            const vehicleSubform = document.getElementById('vehicles-inline-subform');
            const vehicleCreateForm = document.getElementById('vehicles-inline-create-form');
            const vehicleCancelButton = document.getElementById('vehicles-inline-cancel');
            const vehicleCancelFooterButton = document.getElementById('vehicles-inline-cancel-footer');
            let selectedVehicle = null;

            if (!driverFilter || !vehicleSelector || !tableBody) return;

            // Mueve el modal al body para evitar recortes/flicker por contenedores internos.
            if (vehicleSubform && vehicleSubform.parentElement !== document.body) {
                document.body.appendChild(vehicleSubform);
            }

            function safeText(value) {
                if (value === null || value === undefined || String(value).trim() === '') return '-';
                return String(value).trim();
            }

            function normalizeText(value) {
                const text = safeText(value);
                if (text === '-') return '';
                return text.toLowerCase();
            }

            function normalizeStatus(value) {
                const s = normalizeText(value);
                if (s === 'pendiente') return 'programado';
                if (s === 'en curso') return 'en ruta';
                if (s === 'finalizado') return 'entregado';
                return s;
            }

            function getDriverAliases(selectedValue) {
                const selectedNorm = normalizeText(selectedValue);
                if (!selectedNorm) return [];

                const aliases = new Set([selectedNorm]);
                (Array.isArray(choferes) ? choferes : []).forEach(c => {
                    const nameNorm = normalizeText(c.name);
                    const userNorm = normalizeText(c.user);
                    if (selectedNorm === nameNorm || selectedNorm === userNorm) {
                        if (nameNorm) aliases.add(nameNorm);
                        if (userNorm) aliases.add(userNorm);
                    }
                });

                return Array.from(aliases);
            }

            function normalizeText(value) {
                const text = safeText(value);
                if (text === '-') return '';
                return text.toLowerCase();
            }

            function formatDate(value) {
                if (!value) return '-';
                const dt = new Date(value);
                if (Number.isNaN(dt.getTime())) return safeText(value);
                return dt.toLocaleDateString('es-MX');
            }

            function setText(id, value) {
                const el = document.getElementById(id);
                if (el) el.textContent = safeText(value);
            }

            const vehicleSectionDefs = {
                general: {
                    title: 'Datos Generales',
                    fields: [
                        { label: 'Placas', key: 'placas' },
                        { label: 'Numero de unidad', key: 'numero_unidad' },
                        { label: 'Marca', key: 'marca' },
                        { label: 'Modelo', key: 'modelo' },
                        { label: 'Ano', key: 'anio' },
                        { label: 'Tipo de vehiculo', key: 'tipo_vehiculo' },
                        { label: 'VIN', key: 'vin' },
                        { label: 'Capacidad de carga', key: 'capacidad_carga' },
                        { label: 'Combustible', key: 'tipo_combustible' },
                        { label: 'Kilometraje', key: 'kilometraje_actual' },
                        { label: 'Estado', key: 'estado_vehiculo' }
                    ]
                },
                documentacion: {
                    title: 'Documentacion del Vehiculo',
                    fields: [
                        { label: 'Tarjeta de circulacion', key: 'tarjeta_circulacion' },
                        { label: 'Seguro', key: 'seguro' },
                        { label: 'Vencimiento del seguro', key: 'vencimiento_seguro', type: 'date' },
                        { label: 'Verificacion vehicular', key: 'verificacion_vehicular' },
                        { label: 'Permisos/licencias', key: 'permisos_licencias' },
                        { label: 'Propietario', key: 'propietario_vehiculo' },
                        { label: 'Fecha de registro', key: 'fecha_registro', type: 'date' }
                    ]
                },
                mantenimiento: {
                    title: 'Mantenimiento',
                    fields: [
                        { label: 'Ultimo servicio', key: 'fecha_ultimo_servicio', type: 'date' },
                        { label: 'Tipo de servicio', key: 'tipo_servicio' },
                        { label: 'Proximo mantenimiento', key: 'proximo_mantenimiento', type: 'date' },
                        { label: 'Historial de mantenimiento', key: 'historial_mantenimiento' },
                        { label: 'Cambio de aceite', key: 'cambio_aceite' },
                        { label: 'Cambio de llantas', key: 'cambio_llantas' },
                        { label: 'Costo del servicio', key: 'costo_servicio' }
                    ]
                },
                operativo: {
                    title: 'Control Operativo',
                    fields: [
                        { label: 'Conductor asignado', key: 'conductor_asignado' },
                        { label: 'Ruta asignada', key: 'ruta_asignada' },
                        { label: 'Disponibilidad', key: 'disponibilidad' },
                        { label: 'Ubicacion', key: 'ubicacion' },
                        { label: 'Historial de viajes', key: 'historial_viajes' },
                        { label: 'Consumo de combustible', key: 'consumo_combustible' }
                    ]
                }
            };

            function buildSectionRows(sectionKey, vehicle) {
                const section = vehicleSectionDefs[sectionKey];
                if (!section || !vehicle) return [];
                return section.fields.map(field => {
                    const raw = vehicle[field.key];
                    const value = field.type === 'date' ? formatDate(raw) : safeText(raw);
                    return [field.label, value];
                });
            }

            function openSectionPdf(sectionKey) {
                if (!selectedVehicle) {
                    alert('Selecciona un vehiculo para ver su PDF.');
                    return;
                }

                const section = vehicleSectionDefs[sectionKey];
                if (!section) return;

                if (!window.jspdf || !window.jspdf.jsPDF) {
                    alert('No se pudo cargar la libreria PDF.');
                    return;
                }

                const { jsPDF } = window.jspdf;
                const doc = new jsPDF();
                const rows = buildSectionRows(sectionKey, selectedVehicle);

                doc.setFontSize(14);
                doc.text(`Vehiculo - ${section.title}`, 14, 15);
                doc.setFontSize(10);
                doc.text(`Generado: ${new Date().toLocaleString('es-MX')}`, 14, 21);
                doc.text(`Placas: ${safeText(selectedVehicle.placas)} | Unidad: ${safeText(selectedVehicle.numero_unidad)}`, 14, 27);

                if (typeof doc.autoTable === 'function') {
                    doc.autoTable({
                        head: [['Campo', 'Valor']],
                        body: rows,
                        startY: 32,
                        styles: { fontSize: 10 }
                    });
                } else {
                    let y = 34;
                    rows.forEach(([field, value]) => {
                        doc.text(`${field}: ${value}`, 14, y);
                        y += 6;
                    });
                }

                const pdfUrl = doc.output('bloburl');
                window.open(pdfUrl, '_blank');
            }

            const driversFromUsers = (Array.isArray(choferes) ? choferes : [])
                .map(c => safeText(c.name || c.user))
                .filter(v => v !== '-');
            const driversFromVehicles = vehicles
                .map(v => safeText(v.conductor_asignado))
                .filter(v => v !== '-');
            const uniqueDrivers = Array.from(new Set([...driversFromUsers, ...driversFromVehicles])).sort();
            driverFilter.innerHTML = '<option value="">Todos los choferes</option>' + uniqueDrivers.map(d => `<option value="${d}">${d}</option>`).join('');

            let filtered = [...vehicles];

            function getDriverAliases(selectedValue) {
                const selectedNorm = normalizeText(selectedValue);
                if (!selectedNorm) return [];

                const aliases = new Set([selectedNorm]);
                (Array.isArray(choferes) ? choferes : []).forEach(c => {
                    const nameNorm = normalizeText(c.name);
                    const userNorm = normalizeText(c.user);

                    if (selectedNorm === nameNorm || selectedNorm === userNorm) {
                        if (nameNorm) aliases.add(nameNorm);
                        if (userNorm) aliases.add(userNorm);
                    }
                });

                return Array.from(aliases);
            }

            function renderVehicleOptions() {
                if (filtered.length === 0) {
                    vehicleSelector.innerHTML = '<option value="">Sin vehículos</option>';
                    return;
                }
                vehicleSelector.innerHTML = filtered.map((v, index) => {
                    const label = `${safeText(v.placas)} - ${safeText(v.marca)} ${safeText(v.modelo)} (${safeText(v.conductor_asignado)})`;
                    return `<option value="${index}">${label}</option>`;
                }).join('');
            }

            function renderTable(selectedIndex) {
                if (filtered.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="7">Sin vehículos registrados para ese chofer.</td></tr>';
                    return;
                }
                tableBody.innerHTML = filtered.map((v, index) => `
                    <tr data-index="${index}" class="vehicle-edit-row ${index === selectedIndex ? 'selected-vehicle-row' : ''}" data-original-placas="${safeText(v.placas) === '-' ? '' : String(v.placas)}" data-is-new="false" data-original-numero="${safeText(v.numero_unidad) === '-' ? '' : String(v.numero_unidad)}" data-original-tipo="${safeText(v.tipo_vehiculo) === '-' ? '' : String(v.tipo_vehiculo)}" data-original-chofer="${safeText(v.conductor_asignado) === '-' ? '' : String(v.conductor_asignado)}" data-original-estado="${safeText(v.estado_vehiculo) === '-' ? '' : String(v.estado_vehiculo)}" data-original-kilometraje="${safeText(v.kilometraje_actual) === '-' ? '' : String(v.kilometraje_actual)}">
                        <td><input class="users-inline-input vehicle-inline-input" data-field="placas" value="${safeText(v.placas) === '-' ? '' : String(v.placas)}"></td>
