                vehicleCancelButton.addEventListener('click', function () {
                    hideVehicleSubform();
                });
            }

            if (vehicleCancelFooterButton) {
                vehicleCancelFooterButton.addEventListener('click', function () {
                    hideVehicleSubform();
                });
            }

            if (vehicleSubform) {
                vehicleSubform.addEventListener('click', function (event) {
                    if (event.target && event.target.matches('[data-close-vehicles-modal="true"]')) {
                        hideVehicleSubform();
                    }
                });
            }

            if (vehicleCreateForm) {
                vehicleCreateForm.addEventListener('submit', function (event) {
                    event.preventDefault();
                    const formData = new FormData(vehicleCreateForm);
                    const payload = {
                        placas: String(formData.get('placas') || '').trim().toUpperCase(),
                        numero_unidad: String(formData.get('numero_unidad') || '').trim(),
                        marca: String(formData.get('marca') || '').trim(),
                        modelo: String(formData.get('modelo') || '').trim(),
                        anio: String(formData.get('anio') || '').trim(),
                        tipo_vehiculo: String(formData.get('tipo_vehiculo') || '').trim(),
                        vin: String(formData.get('vin') || '').trim(),
                        capacidad_carga: String(formData.get('capacidad_carga') || '').trim(),
                        tipo_combustible: String(formData.get('tipo_combustible') || '').trim(),
                        conductor_asignado: String(formData.get('conductor_asignado') || '').trim(),
                        estado_vehiculo: String(formData.get('estado_vehiculo') || '').trim(),
                        kilometraje_actual: String(formData.get('kilometraje_actual') || '').trim(),
                        tarjeta_circulacion: String(formData.get('tarjeta_circulacion') || '').trim(),
                        seguro: String(formData.get('seguro') || '').trim(),
                        vencimiento_seguro: String(formData.get('vencimiento_seguro') || '').trim(),
                        verificacion_vehicular: String(formData.get('verificacion_vehicular') || '').trim(),
                        permisos_licencias: String(formData.get('permisos_licencias') || '').trim(),
                        propietario_vehiculo: String(formData.get('propietario_vehiculo') || '').trim(),
                        fecha_registro: String(formData.get('fecha_registro') || '').trim(),
                        fecha_ultimo_servicio: String(formData.get('fecha_ultimo_servicio') || '').trim(),
                        tipo_servicio: String(formData.get('tipo_servicio') || '').trim(),
                        proximo_mantenimiento: String(formData.get('proximo_mantenimiento') || '').trim(),
                        historial_mantenimiento: String(formData.get('historial_mantenimiento') || '').trim(),
                        cambio_aceite: String(formData.get('cambio_aceite') || '').trim(),
                        cambio_llantas: String(formData.get('cambio_llantas') || '').trim(),
                        costo_servicio: String(formData.get('costo_servicio') || '').trim(),
                        ruta_asignada: String(formData.get('ruta_asignada') || '').trim(),
                        disponibilidad: String(formData.get('disponibilidad') || '').trim(),
                        ubicacion: String(formData.get('ubicacion') || '').trim(),
                        historial_viajes: String(formData.get('historial_viajes') || '').trim(),
                        consumo_combustible: String(formData.get('consumo_combustible') || '').trim()
                    };

                    if (!payload.placas) {
                        alert('Las placas son obligatorias.');
                        return;
                    }

                    const existingEmpty = tableBody.querySelector('tr td[colspan="7"]');
                    if (existingEmpty) {
                        tableBody.innerHTML = '';
                    }

                    tableBody.prepend(createNewVehicleRow(payload));
                    hideVehicleSubform();
                });
            }

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape' && vehicleSubform && vehicleSubform.classList.contains('is-open')) {
                    hideVehicleSubform();
                }
            });

            if (saveVehiclesButton) {
                saveVehiclesButton.addEventListener('click', async function () {
                    const rows = collectChangedVehicles();
                    if (!rows.length) {
                        alert('No hay cambios pendientes en vehículos.');
                        return;
                    }

                    saveVehiclesButton.disabled = true;
                    const previousLabel = saveVehiclesButton.textContent;
                    saveVehiclesButton.textContent = 'Guardando...';

                    try {
                        const response = await fetch('/admin/vehicles-inline-save', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({ rows: rows })
                        });

                        const result = await response.json();
                        if (!response.ok || !result.ok) {
                            throw new Error(result.message || 'No se pudieron guardar los cambios de flota.');
                        }

                        window.location.href = '/admin?vehiclesExcelStatus=ok&vehiclesExcelSummary=' + encodeURIComponent(result.message || 'Cambios de flota guardados.');
                    } catch (error) {
                        alert(error.message || 'No se pudieron guardar los cambios de flota.');
                    } finally {
                        saveVehiclesButton.disabled = false;
                        saveVehiclesButton.textContent = previousLabel;
                    }
                });
            }

            sectionButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    const sectionKey = this.dataset.section;
                    openSectionPdf(sectionKey);
                });
            });

            refreshView();
        }

