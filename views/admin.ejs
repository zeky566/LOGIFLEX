            function collectChangedVehicles() {
                const rows = Array.from(tableBody.querySelectorAll('.vehicle-edit-row'));
                return rows.reduce(function (accumulator, row) {
                    const payload = getVehicleRowPayload(row);
                    const isNew = row.dataset.isNew === 'true';
                    const changed = isNew
                        || payload.action === 'borrar'
                        || payload.placas !== String(row.dataset.originalPlacas || '')
                        || payload.numero_unidad !== String(row.dataset.originalNumero || '')
                        || payload.tipo_vehiculo !== String(row.dataset.originalTipo || '')
                        || payload.conductor_asignado !== String(row.dataset.originalChofer || '')
                        || payload.estado_vehiculo !== String(row.dataset.originalEstado || '')
                        || payload.kilometraje_actual !== String(row.dataset.originalKilometraje || '');

                    if (changed) accumulator.push(payload);
                    return accumulator;
                }, []);
            }

