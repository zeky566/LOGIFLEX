                            </div>
                            <div class="kpi-card">
                                <div class="kpi-label">Cancelados</div>
                                <div class="kpi-value" id="kpi-cancelled-trips">0</div>
                            </div>
                            <div class="kpi-card">
                                <div class="kpi-label">Costo total</div>
                                <div class="kpi-value" id="kpi-total-cost">$0.00</div>
                            </div>
                            <div class="kpi-card">
                                <div class="kpi-label">Ganancia neta</div>
                                <div class="kpi-value" id="kpi-net-profit">$0.00</div>
                            </div>
                        </div>

                        <div class="buttons-wrap">
                            <button id="btn-export-pdf" class="btn secondary">Exportar PDF</button>
                            <button id="btn-export-excel" class="btn success">Exportar Excel</button>
                            <button id="btn-print-report" class="btn warning">Imprimir reporte</button>
                            <button id="btn-clear-report-filters" class="btn danger">Limpiar filtros</button>
                        </div>

                        <h3 id="report-preview-title" class="section-title">Vista previa del reporte</h3>
                        <div class="table-container">
                            <!-- Tabla de vista previa del reporte seleccionado -->
                            <table id="report-preview-table">
                                <thead id="report-preview-head"></thead>
                                <tbody id="report-preview-body">
                                    <tr><td class="empty">Genera un reporte para ver datos.</td></tr>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </main>

                <script id="reports-trips-data" type="application/json"><%- JSON.stringify(Array.isArray(dbViajes) ? dbViajes : []) %></script>
                <script id="reports-vehicles-data" type="application/json"><%- JSON.stringify(Array.isArray(dbVehiculos) ? dbVehiculos : []) %></script>
                <script id="reports-expenses-data" type="application/json"><%- JSON.stringify(Array.isArray(dbDriverExpenses) ? dbDriverExpenses : []) %></script>

                <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
                <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
                <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
                <script>
                    (function () {
                        const LS_KEY = 'transportReports';
                        let reports = JSON.parse(localStorage.getItem(LS_KEY)) || [];
                        let currentReport = null;

                        function readJsonData(id) {
                            const n = document.getElementById(id);
                            if (!n) return [];
                            try { return JSON.parse(n.textContent || '[]'); } catch (e) { return []; }
                        }

                        const dbTrips = readJsonData('reports-trips-data');
                        const dbVehicles = readJsonData('reports-vehicles-data');
                        const dbDriverExpenses = readJsonData('reports-expenses-data');
                        const lsTrips = JSON.parse(localStorage.getItem('transportTrips')) || [];

                        // Limpia datos legacy de viajes cuando ya hay datos reales en BD.
                        if (Array.isArray(dbTrips) && dbTrips.length > 0) {
                            localStorage.removeItem('transportTrips');
                        }

                        // Se priorizan viajes de base de datos para reflejar rutas reales del cliente.
                        const trips = Array.isArray(dbTrips) && dbTrips.length > 0 ? dbTrips : lsTrips;
                        const vehicles = dbVehicles;

                        const fromDate = document.getElementById('rep-from-date');
                        const toDate = document.getElementById('rep-to-date');
                        const vehicleFilter = document.getElementById('rep-vehicle-filter');
                        const driverFilter = document.getElementById('rep-driver-filter');
                        const clientFilter = document.getElementById('rep-client-filter');
                        const routeFilter = document.getElementById('rep-route-filter');

                        const previewTitle = document.getElementById('report-preview-title');
                        const previewHead = document.getElementById('report-preview-head');
                        const previewBody = document.getElementById('report-preview-body');
                        const reportsBody = document.getElementById('reports-body');
                        const reportTypeSelect = document.getElementById('rep-type-select');
                        const reportState = document.getElementById('report-state');
                        const btnGenerateReport = document.getElementById('btn-generate-report');
                        const reportTypeButtons = Array.from(document.querySelectorAll('[data-report-type]'));
                        const btnExportPdf = document.getElementById('btn-export-pdf');
                        const btnExportExcel = document.getElementById('btn-export-excel');
                        const btnPrintReport = document.getElementById('btn-print-report');
                        const kpiTotalTrips = document.getElementById('kpi-total-trips');
                        const kpiActiveTrips = document.getElementById('kpi-active-trips');
                        const kpiCancelledTrips = document.getElementById('kpi-cancelled-trips');
                        const kpiTotalCost = document.getElementById('kpi-total-cost');
                        const kpiNetProfit = document.getElementById('kpi-net-profit');
                        let currentReportType = 'Viajes';

                        function saveHistory() {
                            localStorage.setItem(LS_KEY, JSON.stringify(reports));
                            renderHistory();
                        }

                        function fDate(d) {
                            if (!d) return 'N/A';
                            const dt = new Date(d);
                            return Number.isNaN(dt.getTime()) ? String(d) : dt.toLocaleDateString('es-MX');
                        }

                        function normalizeText(value) {
                            if (value === null || value === undefined) return '';
                            return String(value).trim().toLowerCase();
                        }

                        function parseHours(value) {
                            const text = String(value || '').trim().toLowerCase();
                            if (!text) return 0;

                            const match = text.match(/\d+(?:[\.,]\d+)?/);
                            if (!match) return 0;

                            const num = Number(String(match[0]).replace(',', '.'));
                            return Number.isFinite(num) ? num : 0;
                        }

                        function normalizeTrip(t, idx) {
                            const id = t.trip_id || t.id || ('V-' + String(idx + 1).padStart(3, '0'));
                            const origin = t.origen || t.origin || '';
                            const destination = t.destino || t.destination || '';
                            const vehicle = t.vehiculo_asignado || t.vehicle || '';
                            const driver = t.conductor || t.driver || '';
                            const client = t.cliente || t.clientName || '';
                            const status = t.estado_viaje || t.status || '';
                            const departure = t.fecha_salida || t.startDate || t.date || '';
                            return {
                                id, origin, destination, vehicle, driver, client, status,
                                departure,
                                estimatedArrival: t.fecha_llegada_estimada || t.endDate || '',
                                fuel: Number(t.combustible || 0) || 0,
                                tolls: Number(t.peajes || 0) || 0,
                                viatic: Number(t.viaticos || 0) || 0,
                                totalCost: Number(t.costo_total || 0) || 0,
                                profit: Number(t.ganancia || 0) || 0,
                                incidents: t.incidentes || '',
                                estimatedHours: parseHours(t.tiempo_estimado)
                            };
                        }

                        const normalizedTrips = trips.map(normalizeTrip);

                        const normalizedExpenses = (Array.isArray(dbDriverExpenses) ? dbDriverExpenses : []).map((e, idx) => {
                            const amount = Number(e.monto || 0) || 0;
                            return {
                                id: Number(e.id || (idx + 1)),
                                driver: String(e.chofer || '').trim(),
                                type: String(e.tipo_gasto || '').trim(),
                                description: String(e.descripcion || '').trim(),
                                amount,
                                date: e.fecha || e.created_at || ''
                            };
                        });

                        function periodLabel() {
                            const f = fromDate.value;
                            const t = toDate.value;
                            if (f && t) return `${f} -> ${t}`;
                            if (f) return `Desde ${f}`;
                            if (t) return `Hasta ${t}`;
                            return 'Completo';
                        }

                        function isInRange(dateValue) {
                            if (!dateValue) return true;
                            const d = new Date(dateValue);
                            if (Number.isNaN(d.getTime())) return true;
                            const f = fromDate.value ? new Date(fromDate.value) : null;
                            const t = toDate.value ? new Date(toDate.value) : null;
                            if (f && d < f) return false;
                            if (t && d > new Date(t.getFullYear(), t.getMonth(), t.getDate(), 23, 59, 59)) return false;
                            return true;
                        }

                        function applyTripFilters(list) {
                            return list.filter(t => {
                                if (!isInRange(t.departure)) return false;
                                if (vehicleFilter.value && normalizeText(t.vehicle) !== normalizeText(vehicleFilter.value)) return false;
                                if (driverFilter.value && normalizeText(t.driver) !== normalizeText(driverFilter.value)) return false;
                                if (clientFilter.value && normalizeText(t.client) !== normalizeText(clientFilter.value)) return false;
                                const routeLabel = `${t.origin} -> ${t.destination}`;
                                if (routeFilter.value && normalizeText(routeLabel) !== normalizeText(routeFilter.value)) return false;
                                return true;
                            });
                        }

                        function applyExpenseFilters(list) {
                            return list.filter(e => {
                                if (!isInRange(e.date)) return false;

                                // Como los gastos no tienen trip_id, solo se filtran por chofer y fecha.
                                if (driverFilter.value && normalizeText(e.driver) !== normalizeText(driverFilter.value)) return false;

                                // Si se filtra por vehículo/cliente/ruta, no se pueden mapear gastos sin viaje.
                                if (vehicleFilter.value || clientFilter.value || routeFilter.value) return false;

                                return true;
                            });
                        }

                        function money(value) {
                            return `$${Number(value || 0).toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
                        }

                        function setKpiTone(el, tone) {
                            if (!el) return;
                            el.classList.remove('kpi-good', 'kpi-warn', 'kpi-bad');
                            if (tone === 'good') el.classList.add('kpi-good');
                            if (tone === 'warn') el.classList.add('kpi-warn');
                            if (tone === 'bad') el.classList.add('kpi-bad');
                        }

                        function updateKpis() {
                            const filtered = applyTripFilters(normalizedTrips);
                            const filteredExpenses = applyExpenseFilters(normalizedExpenses);
                            const activeStatuses = ['programado', 'en carga', 'en ruta'];

                            const totalTrips = filtered.length;
                            const activeTrips = filtered.filter(t => activeStatuses.includes(String(t.status || '').toLowerCase())).length;
                            const cancelledTrips = filtered.filter(t => String(t.status || '').toLowerCase() === 'cancelado').length;

                            const tripCost = filtered.reduce((acc, t) => {
                                const c = Number(t.totalCost || (t.fuel + t.tolls + t.viatic) || 0) || 0;
                                return acc + c;
                            }, 0);

                            const expenseCost = filteredExpenses.reduce((acc, e) => acc + (Number(e.amount || 0) || 0), 0);
                            const totalCost = tripCost + expenseCost;

                            // "ganancia" ya representa el valor final del viaje.
                            const netProfit = filtered.reduce((acc, t) => acc + (Number(t.profit || 0) || 0), 0) - expenseCost;

                            if (kpiTotalTrips) kpiTotalTrips.textContent = String(totalTrips);
                            if (kpiActiveTrips) kpiActiveTrips.textContent = String(activeTrips);
                            if (kpiCancelledTrips) kpiCancelledTrips.textContent = String(cancelledTrips);
                            if (kpiTotalCost) kpiTotalCost.textContent = money(totalCost);
                            if (kpiNetProfit) kpiNetProfit.textContent = money(netProfit);

                            const activeRatio = totalTrips > 0 ? (activeTrips / totalTrips) : 1;
                            const avgCost = totalTrips > 0 ? (totalCost / totalTrips) : 0;

                            setKpiTone(kpiTotalTrips, totalTrips >= 8 ? 'good' : (totalTrips >= 3 ? 'warn' : 'bad'));
                            setKpiTone(kpiActiveTrips, activeRatio <= 0.4 ? 'good' : (activeRatio <= 0.7 ? 'warn' : 'bad'));
                            setKpiTone(kpiCancelledTrips, cancelledTrips === 0 ? 'good' : (cancelledTrips <= 2 ? 'warn' : 'bad'));
                            setKpiTone(kpiTotalCost, avgCost <= 800 ? 'good' : (avgCost <= 1800 ? 'warn' : 'bad'));
                            setKpiTone(kpiNetProfit, netProfit > 0 ? 'good' : (netProfit === 0 ? 'warn' : 'bad'));
                        }

                        function populateFilters() {
                            const vehicleSet = Array.from(new Set(normalizedTrips.map(t => t.vehicle).filter(Boolean)));
                            const driverSet = Array.from(new Set(normalizedTrips.map(t => t.driver).filter(Boolean)));
                            const clientSet = Array.from(new Set(normalizedTrips.map(t => t.client).filter(Boolean)));
                            const routeSet = Array.from(new Set(normalizedTrips.map(t => `${t.origin} -> ${t.destination}`).filter(v => v !== ' -> ')));

                            vehicleSet.forEach(v => vehicleFilter.insertAdjacentHTML('beforeend', `<option value="${v}">${v}</option>`));
                            driverSet.forEach(v => driverFilter.insertAdjacentHTML('beforeend', `<option value="${v}">${v}</option>`));
                            clientSet.forEach(v => clientFilter.insertAdjacentHTML('beforeend', `<option value="${v}">${v}</option>`));
                            routeSet.forEach(v => routeFilter.insertAdjacentHTML('beforeend', `<option value="${v}">${v}</option>`));
                        }

                        function renderPreview(report) {
                            currentReport = report;
                            previewTitle.textContent = report.title;

                            if (!report.rows || report.rows.length === 0) {
                                previewHead.innerHTML = '';
                                const totalBase = Array.isArray(normalizedTrips) ? normalizedTrips.length : 0;
                                const baseHint = totalBase > 0
                                    ? `Hay ${totalBase} viaje(s) registrados, pero no coinciden con los filtros actuales.`
                                    : 'No hay viajes registrados todavía en la base de datos.';
                                previewBody.innerHTML = `<tr><td class="empty">No hay datos para los filtros seleccionados. ${baseHint}</td></tr>`;
                                setExportButtonsEnabled(false);
                                setReportStateText(0);
                                return;
                            }

                            previewHead.innerHTML = `<tr>${report.headers.map(h => `<th>${h}</th>`).join('')}</tr>`;
                            previewBody.innerHTML = report.rows.map(r => `<tr>${report.headers.map(h => `<td>${r[h] ?? ''}</td>`).join('')}</tr>`).join('');
                            setExportButtonsEnabled(true);
                            setReportStateText(report.rows.length);
                        }

                        function toInputDate(date) {
                            const y = date.getFullYear();
                            const m = String(date.getMonth() + 1).padStart(2, '0');
                            const d = String(date.getDate()).padStart(2, '0');
                            return `${y}-${m}-${d}`;
                        }

                        function setDateRange(mode) {
                            const now = new Date();
                            if (mode === 'today') {
                                const today = toInputDate(now);
                                fromDate.value = today;
                                toDate.value = today;
                                return;
                            }

                            if (mode === 'week') {
                                const from = new Date(now);
                                from.setDate(from.getDate() - 6);
                                fromDate.value = toInputDate(from);
                                toDate.value = toInputDate(now);
                                return;
                            }

                            if (mode === 'month') {
                                const from = new Date(now.getFullYear(), now.getMonth(), 1);
                                fromDate.value = toInputDate(from);
                                toDate.value = toInputDate(now);
                                return;
                            }

                            fromDate.value = '';
                            toDate.value = '';
                        }

                        function setExportButtonsEnabled(enabled) {
                            [btnExportPdf, btnExportExcel, btnPrintReport].forEach(btn => {
                                if (!btn) return;
                                btn.disabled = !enabled;
                            });
                        }

                        function getAppliedFiltersText() {
                            const parts = [];
                            if (fromDate.value || toDate.value) parts.push(`Fecha: ${fromDate.value || 'inicio abierto'} a ${toDate.value || 'fin abierto'}`);
                            if (vehicleFilter.value) parts.push(`Vehículo: ${vehicleFilter.value}`);
                            if (driverFilter.value) parts.push(`Conductor: ${driverFilter.value}`);
                            if (clientFilter.value) parts.push(`Cliente: ${clientFilter.value}`);
                            if (routeFilter.value) parts.push(`Ruta: ${routeFilter.value}`);
                            return parts.length ? parts.join(' | ') : 'Sin filtros (mostrando todo)';
                        }

                        function setReportStateText(rowCount) {
                            if (!reportState) return;
                            reportState.textContent = `Tipo: ${currentReportType}. Filas: ${rowCount}. ${getAppliedFiltersText()}`;
                        }

                        function setActiveReportType(type) {
                            currentReportType = String(type || 'Viajes');
                            if (reportTypeSelect) reportTypeSelect.value = currentReportType;
                            reportTypeButtons.forEach(btn => {
                                const btnType = String(btn.dataset.reportType || '');
                                btn.classList.toggle('is-active', btnType === currentReportType);
                            });
                        }

                        function makeTripsReport() {
                            const data = applyTripFilters(normalizedTrips);
                            return {
                                type: 'Viajes',
                                title: 'Reporte de Viajes',
                                headers: ['Viaje', 'Vehículo', 'Conductor', 'Estado', 'Cliente', 'Fecha'],
                                rows: data.map(t => ({
                                    Viaje: t.id,
                                    Vehículo: t.vehicle || '-',
                                    Conductor: t.driver || '-',
                                    Estado: t.status || '-',
                                    Cliente: t.client || '-',
                                    Fecha: fDate(t.departure)
                                }))
                            };
                        }

                        function makeVehiclesReport() {
                            const filteredTrips = applyTripFilters(normalizedTrips);
                            const usedVehicles = new Set(filteredTrips.map(t => String(t.vehicle || '').trim()).filter(Boolean));

                            let data = [];
                            if (vehicles.length > 0 && usedVehicles.size > 0) {
                                data = vehicles.filter(v => {
                                    const placa = String(v.placas || '').trim();
                                    const unidad = String(v.numero_unidad || '').trim();
                                    return usedVehicles.has(placa) || usedVehicles.has(unidad);
                                });
                            }

                            if (data.length === 0) {
                                data = filteredTrips.map(t => ({
                                    placas: t.vehicle,
                                    estado_vehiculo: t.status,
                                    kilometraje_actual: '-',
                                    tipo_combustible: '-'
                                }));
                            }

                            return {
                                type: 'Vehículos',
                                title: 'Reporte de Vehículos',
                                headers: ['Vehículo', 'Estado', 'Kilometraje', 'Combustible', 'Mantenimiento'],
                                rows: data.map(v => ({
                                    Vehículo: v.placas || v.numero_unidad || '-',
                                    Estado: v.estado_vehiculo || '-',
                                    Kilometraje: v.kilometraje_actual ?? '-',
                                    Combustible: v.tipo_combustible || '-',
                                    Mantenimiento: v.historial_mantenimiento || '-'
                                }))
                            };
                        }

                        function makeDriversReport() {
                            const data = applyTripFilters(normalizedTrips);
                            const grouped = {};
                            data.forEach(t => {
                                const k = t.driver || 'Sin conductor';
                                if (!grouped[k]) grouped[k] = { viajes: 0, incidents: 0, delivered: 0, hours: 0 };
                                grouped[k].viajes += 1;
                                if ((t.incidents || '').trim()) grouped[k].incidents += 1;
                                if (String(t.status).toLowerCase() === 'entregado') grouped[k].delivered += 1;
                                grouped[k].hours += Number(t.estimatedHours || 0) || 0;
                            });

                            return {
                                type: 'Conductores',
                                title: 'Reporte de Conductores',
                                headers: ['Conductor', 'Viajes', 'Incidentes', 'Horas trabajadas', 'Rendimiento'],
                                rows: Object.keys(grouped).map(name => ({
                                    Conductor: name,
                                    Viajes: grouped[name].viajes,
                                    Incidentes: grouped[name].incidents,
                                    'Horas trabajadas': Number(grouped[name].hours || 0).toFixed(1),
                                    Rendimiento: grouped[name].viajes > 0 ? `${Math.round((grouped[name].delivered / grouped[name].viajes) * 100)}%` : '0%'
                                }))
                            };
                        }

                        function makeFinancialReport() {
                            const data = applyTripFilters(normalizedTrips);
                            const expenseData = applyExpenseFilters(normalizedExpenses);

                            return {
                                type: 'Financiero',
                                title: 'Reporte Financiero',
                                headers: ['Viaje', 'Costo viaje', 'Combustible', 'Peajes', 'Ganancia', 'Balance'],
                                rows: [
                                    ...data.map(t => {
                                    const total = Number(t.totalCost || (t.fuel + t.tolls + t.viatic) || 0) || 0;
                                    const gain = t.profit || 0;
                                    return {
                                        Viaje: t.id,
                                        'Costo viaje': total.toFixed(2),
                                        Combustible: (Number(t.fuel || 0) || 0).toFixed(2),
                                        Peajes: (Number(t.tolls || 0) || 0).toFixed(2),
                                        Ganancia: gain.toFixed(2),
                                        Balance: (gain - total).toFixed(2)
                                    };
                                    }),
                                    ...expenseData.map(e => ({
                                        Viaje: `Gasto chofer: ${e.driver || 'Sin chofer'}`,
                                        'Costo viaje': Number(e.amount || 0).toFixed(2),
                                        Combustible: String(e.type || '').toLowerCase().includes('combust') ? Number(e.amount || 0).toFixed(2) : '0.00',
                                        Peajes: String(e.type || '').toLowerCase().includes('peaje') ? Number(e.amount || 0).toFixed(2) : '0.00',
                                        Ganancia: '0.00',
                                        Balance: (-Number(e.amount || 0)).toFixed(2)
                                    }))
                                ]
                            };
                        }

                        function makeClientsReport() {
                            const data = applyTripFilters(normalizedTrips);
                            const grouped = {};
                            data.forEach(t => {
                                const k = t.client || 'Sin cliente';
                                if (!grouped[k]) grouped[k] = { trips: 0, delivered: 0 };
                                grouped[k].trips += 1;
                                if (String(t.status).toLowerCase() === 'entregado') grouped[k].delivered += 1;
                            });
                            return {
                                type: 'Clientes',
                                title: 'Reporte de Clientes',
                                headers: ['Cliente', 'Viajes', 'Entregas', 'Historial de servicios'],
                                rows: Object.keys(grouped).map(c => ({
                                    Cliente: c,
                                    Viajes: grouped[c].trips,
                                    Entregas: grouped[c].delivered,
                                    'Historial de servicios': grouped[c].trips
                                }))
                            };
                        }

                        function renderHistory() {
                            if (!reportsBody) return;
                            if (!reports.length) {
                                reportsBody.innerHTML = '<tr><td colspan="5" class="empty">No hay reportes generados</td></tr>';
                                return;
                            }
                            reportsBody.innerHTML = reports.map(r => `
                                <tr>
                                    <td>REP-${String(r.id).padStart(3, '0')}</td>
                                    <td>${r.type}</td>
                                    <td>${r.period}</td>
                                    <td>${fDate(r.generatedAt)}</td>
                                    <td>
                                        <button class="btn secondary" data-action="view" data-id="${r.id}">Ver</button>
                                        <a class="btn success" href="${r.dataUrl}" download="${r.fileName}">Descargar</a>
                                        <button class="btn danger" data-action="delete" data-id="${r.id}">Eliminar</button>
                                    </td>
                                </tr>
                            `).join('');
                        }

                        function pushHistory(type, ext, blob) {
                            const id = reports.length ? Math.max(...reports.map(r => r.id)) + 1 : 1;
                            const fileName = `reporte_${type.toLowerCase()}_${new Date().toISOString().slice(0, 10)}.${ext}`;
                            const dataUrl = URL.createObjectURL(blob);
                            reports.unshift({
                                id,
                                type,
                                period: periodLabel(),
                                generatedAt: new Date().toISOString(),
                                dataUrl,
                                fileName
                            });
                            saveHistory();
                        }

                        function exportPDF() {
                            if (!ensureReportWithData('exportar PDF')) return;
                            const { jsPDF } = window.jspdf;
                            const doc = new jsPDF();
                            doc.text(`${currentReport.title} (${periodLabel()})`, 14, 16);
                            doc.autoTable({ head: [currentReport.headers], body: currentReport.rows.map(r => currentReport.headers.map(h => String(r[h] ?? ''))), startY: 24, styles: { fontSize: 8 } });
                            const blob = doc.output('blob');
                            pushHistory(currentReport.type, 'pdf', blob);
                            window.open(URL.createObjectURL(blob), '_blank');
                        }

                        function exportExcel() {
                            if (!ensureReportWithData('exportar Excel')) return;
                            const wb = XLSX.utils.book_new();
                            const ws = XLSX.utils.json_to_sheet(currentReport.rows, { header: currentReport.headers });
                            ws['!cols'] = currentReport.headers.map(() => ({ wch: 22 }));
                            XLSX.utils.book_append_sheet(wb, ws, 'reporte');
                            const arr = XLSX.write(wb, { type: 'array', bookType: 'xlsx' });
                            const blob = new Blob([arr], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                            pushHistory(currentReport.type, 'xlsx', blob);
                            const link = document.createElement('a');
                            link.href = URL.createObjectURL(blob);
                            link.download = `reporte_${currentReport.type.toLowerCase()}_${new Date().toISOString().slice(0, 10)}.xlsx`;
                            link.click();
                        }

                        function printCurrentReport() {
                            if (!ensureReportWithData('imprimir')) return;
                            const w = window.open('', '_blank');
                            const head = `<tr>${currentReport.headers.map(h => `<th style="text-align:left;padding:8px;border-bottom:1px solid #ccc;">${h}</th>`).join('')}</tr>`;
                            const body = currentReport.rows.map(r => `<tr>${currentReport.headers.map(h => `<td style="padding:8px;border-bottom:1px solid #eee;">${r[h] ?? ''}</td>`).join('')}</tr>`).join('');
                            // Tabla HTML temporal para imprimir el reporte actual.
                            w.document.write(`<html><head><title>${currentReport.title}</title></head><body><h2>${currentReport.title}</h2><p>${periodLabel()}</p><table style="width:100%;border-collapse:collapse;">${head}${body}</table></body></html>`);
                            w.document.close();
                            w.focus();
                            w.print();
                        }

                        function buildReportByType(type) {
                            const key = String(type || '').toLowerCase();
                            if (key === 'viajes') return makeTripsReport();
                            if (key === 'vehículos' || key === 'vehiculos') return makeVehiclesReport();
                            if (key === 'conductores') return makeDriversReport();
                            if (key === 'financiero') return makeFinancialReport();
                            if (key === 'clientes') return makeClientsReport();
                            return makeTripsReport();
                        }

                        function clearReportFilters() {
                            fromDate.value = '';
                            toDate.value = '';
                            vehicleFilter.value = '';
                            driverFilter.value = '';
                            clientFilter.value = '';
                            routeFilter.value = '';
                        }

                        function renderCurrentReport() {
                            const next = buildReportByType(currentReportType);
                            renderPreview(next);
                            return next;
                        }

                        function ensureReportWithData(actionName) {
                            const hasRows = currentReport && Array.isArray(currentReport.rows) && currentReport.rows.length > 0;
                            if (hasRows) return true;

                            const existsTrips = Array.isArray(normalizedTrips) && normalizedTrips.length > 0;
                            if (!existsTrips) {
                                alert('No hay viajes registrados para generar reportes.');
                                return false;
                            }

                            const confirmReset = confirm(`No hay datos con los filtros actuales para ${actionName}. ¿Deseas limpiar filtros y usar todos los viajes?`);
                            if (!confirmReset) return false;

                            clearReportFilters();
                            updateKpis();
                            const refreshed = renderCurrentReport();
                            return refreshed && Array.isArray(refreshed.rows) && refreshed.rows.length > 0;
                        }

                        reportTypeButtons.forEach(btn => {
                            btn.addEventListener('click', () => {
                                setActiveReportType(btn.dataset.reportType || 'Viajes');
                                renderCurrentReport();
                            });
                        });

                        if (reportTypeSelect) {
                            reportTypeSelect.addEventListener('change', () => {
                                setActiveReportType(reportTypeSelect.value || 'Viajes');
                                renderCurrentReport();
                            });
                        }

                        if (btnGenerateReport) {
                            btnGenerateReport.addEventListener('click', () => {
                                if (reportTypeSelect) {
                                    setActiveReportType(reportTypeSelect.value || 'Viajes');
                                }
                                updateKpis();
                                const generated = renderCurrentReport();

                                const hasRows = generated && Array.isArray(generated.rows) && generated.rows.length > 0;
                                const hasTrips = Array.isArray(normalizedTrips) && normalizedTrips.length > 0;
                                if (!hasRows && hasTrips) {
                                    const shouldReset = confirm('No hay datos con los filtros actuales. ¿Deseas limpiar filtros y generar el reporte con todos los datos?');
                                    if (shouldReset) {
                                        clearReportFilters();
                                        updateKpis();
                                        renderCurrentReport();
                                    }
                                }
                            });
                        }

                        document.getElementById('btn-range-today').addEventListener('click', () => {
                            setDateRange('today');
                            updateKpis();
                            renderCurrentReport();
                        });
                        document.getElementById('btn-range-week').addEventListener('click', () => {
                            setDateRange('week');
                            updateKpis();
                            renderCurrentReport();
                        });
                        document.getElementById('btn-range-month').addEventListener('click', () => {
                            setDateRange('month');
                            updateKpis();
                            renderCurrentReport();
                        });
                        document.getElementById('btn-range-all').addEventListener('click', () => {
                            setDateRange('all');
                            updateKpis();
                            renderCurrentReport();
                        });

                        btnExportPdf.addEventListener('click', exportPDF);
                        btnExportExcel.addEventListener('click', exportExcel);
                        btnPrintReport.addEventListener('click', printCurrentReport);
                        document.getElementById('btn-clear-report-filters').addEventListener('click', () => {
                            clearReportFilters();
                            updateKpis();
                            renderCurrentReport();
                        });

                        [fromDate, toDate, vehicleFilter, driverFilter, clientFilter, routeFilter].forEach(ctrl => {
                            const refreshWithFilters = () => {
                                updateKpis();
                                renderCurrentReport();
                            };

                            ctrl.addEventListener('change', refreshWithFilters);
                            ctrl.addEventListener('input', refreshWithFilters);
                        });

                        if (reportsBody) {
                            reportsBody.addEventListener('click', function (e) {
                                const btn = e.target.closest('button');
                                if (!btn) return;
                                const id = Number(btn.dataset.id);
                                const action = btn.dataset.action;
                                const rep = reports.find(r => r.id === id);
                                if (!rep) return;
                                if (action === 'view') window.open(rep.dataUrl, '_blank');
                                if (action === 'delete') {
                                    if (!confirm('¿Eliminar reporte?')) return;
                                    reports = reports.filter(r => r.id !== id);
                                    saveHistory();
                                }
                            });
                        }

                        populateFilters();
                        // Evita filtros restaurados por el navegador que dejen la vista en 0 por defecto.
                        clearReportFilters();
                        setActiveReportType('Viajes');
                        updateKpis();
                        renderCurrentReport();
                        renderHistory();
                    })();
                </script>
            </div>

