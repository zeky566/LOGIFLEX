                    <script>
                        (function () {
                            const tabs = Array.from(document.querySelectorAll('.users-role-tab'));
                            const panels = Array.from(document.querySelectorAll('.users-role-panel'));
                            const addButton = document.getElementById('users-inline-add');
                            const saveButton = document.getElementById('users-inline-save');
                            const feedback = document.getElementById('users-inline-feedback');
                            const createForms = Array.from(document.querySelectorAll('.users-inline-create-form'));
                            const subform = document.getElementById('users-inline-subform');
                            const subformDialog = subform ? subform.querySelector('.users-inline-modal-dialog') : null;
                            const subformTitle = document.getElementById('users-inline-subform-title');
                            const cancelSubformButton = document.getElementById('users-inline-cancel');
                            const cancelSubformFooterButtons = Array.from(document.querySelectorAll('.users-inline-cancel-footer'));

                            if (!tabs.length || !panels.length) return;

                            // Mueve el modal al body para evitar recortes/flicker por contenedores internos.
                            if (subform && subform.parentElement !== document.body) {
                                document.body.appendChild(subform);
                            }

                            function getCreateFormByRole(role) {
                                return createForms.find(function (form) {
                                    return form.dataset.createRole === role;
                                }) || createForms[0] || null;
                            }

                            function showRoleForm(role) {
                                createForms.forEach(function (form) {
                                    form.hidden = form.dataset.createRole !== role;
                                    if (form.hidden) form.reset();
                                });
                            }

                            function setFeedback(type, message) {
                                if (!feedback) return;
                                feedback.hidden = false;
                                feedback.textContent = message;
                                feedback.classList.remove('excel-error', 'excel-success');
                                feedback.classList.add(type === 'error' ? 'excel-error' : 'excel-success');
                            }

                            function showPanel(key) {
                                tabs.forEach(function (tab) {
                                    tab.classList.toggle('is-active', tab.dataset.usersTab === key);
                                });

                                panels.forEach(function (panel) {
                                    panel.classList.toggle('is-visible', panel.dataset.usersPanel === key);
                                });

                                hideSubform();
                            }

                            function getActivePanel() {
                                return panels.find(function (panel) {
                                    return panel.classList.contains('is-visible');
                                }) || panels[0];
                            }

                            function updateRowIndexes(panel) {
                                const body = panel ? panel.querySelector('tbody[data-users-role]') : null;
                                if (!body) return;
                                const rows = Array.from(body.querySelectorAll('.users-edit-row'));
                                rows.forEach(function (row, index) {
                                    const indexCell = row.querySelector('.users-row-index');
                                    if (indexCell) indexCell.textContent = index + 1;
                                });
                            }

                            function ensureEmptyState(body) {
                                const editableRows = body.querySelectorAll('.users-edit-row');
                                let emptyRow = body.querySelector('.users-empty-row');

                                if (editableRows.length === 0 && !emptyRow) {
                                    emptyRow = document.createElement('tr');
                                    emptyRow.className = 'users-empty-row';
                                    emptyRow.innerHTML = '<td colspan="6">No hay registros en esta categoría.</td>';
                                    body.appendChild(emptyRow);
                                }

                                if (editableRows.length > 0 && emptyRow) {
                                    emptyRow.remove();
                                }
                            }

                            function createEditableRow(role) {
                                return createEditableRowWithValues(role, {
                                    user: '',
                                    name: '',
                                    telefono: '',
                                    pass: ''
                                });
                            }

                            function createEditableRowWithValues(role, values) {
                                const row = document.createElement('tr');
                                row.className = 'users-edit-row';
                                row.dataset.originalUser = '';
                                row.dataset.role = role;
                                row.dataset.isNew = 'true';
                                row.innerHTML = [
                                    '<td class="users-row-index"></td>',
                                    '<td><input class="users-inline-input" type="text" data-field="user" placeholder="Usuario" value="' + (values.user || '') + '"></td>',
                                    '<td><input class="users-inline-input" type="text" data-field="name" placeholder="Nombre completo" value="' + (values.name || '') + '"></td>',
                                    '<td><input class="users-inline-input" type="tel" data-field="telefono" placeholder="Teléfono" value="' + (values.telefono || '') + '"></td>',
                                    '<td><input class="users-inline-input" type="password" data-field="pass" placeholder="Contraseña obligatoria" value="' + (values.pass || '') + '"></td>',
                                    '<td><button type="button" class="users-row-delete">Eliminar</button></td>'
                                ].join('');
                                return row;
                            }

                            function getRoleLabel(role) {
                                if (role === 'chofer') return 'chofer';
                                if (role === 'admin') return 'administrador';
                                return 'cliente';
                            }

                            function getActiveRole() {
                                const activePanel = getActivePanel();
                                const body = activePanel ? activePanel.querySelector('tbody[data-users-role]') : null;
                                return body ? (body.dataset.usersRole || 'cliente') : 'cliente';
                            }

                            function showSubform() {
                                if (!subform || !createForms.length) return;
                                const normalizedRole = getActiveRole();
                                const roleLabel = getRoleLabel(normalizedRole);
                                showRoleForm(normalizedRole);
                                subform.classList.add('is-open');
                                subform.setAttribute('aria-hidden', 'false');
                                if (subformDialog) {
                                    subformDialog.classList.remove('role-cliente', 'role-chofer', 'role-admin');
                                    subformDialog.classList.add('role-' + normalizedRole);
                                }
                                document.body.classList.add('users-modal-open');
                                if (subformTitle) {
                                    subformTitle.textContent = 'Agregar ' + roleLabel;
                                }
                                const activeCreateForm = getCreateFormByRole(normalizedRole);
                                if (activeCreateForm) activeCreateForm.reset();
                                const firstInput = activeCreateForm ? activeCreateForm.querySelector('input[name="user"]') : null;
                                if (firstInput) firstInput.focus();
                            }

                            function hideSubform() {
                                if (!subform || !createForms.length) return;
                                subform.classList.remove('is-open');
                                subform.setAttribute('aria-hidden', 'true');
                                document.body.classList.remove('users-modal-open');
                                createForms.forEach(function (form) {
                                    form.reset();
                                });
                            }

                            function getRowPayload(row) {
                                const role = row.dataset.role || '';
                                const action = row.classList.contains('is-pending-delete') ? 'borrar' : 'actualizar';
                                const getValue = function (field) {
                                    const input = row.querySelector('[data-field="' + field + '"]');
                                    return input ? input.value.trim() : '';
                                };

                                return {
                                    action: action,
                                    originalUser: row.dataset.originalUser || '',
                                    user: getValue('user'),
                                    name: getValue('name'),
                                    telefono: getValue('telefono'),
                                    pass: getValue('pass'),
                                    rol: getRoleLabel(role)
                                };
                            }

                            function collectChangedRows() {
                                const rows = Array.from(document.querySelectorAll('.users-edit-row'));
                                return rows.reduce(function (accumulator, row) {
                                    const payload = getRowPayload(row);
                                    const isNew = row.dataset.isNew === 'true';
                                    const originalUser = row.dataset.originalUser || '';
                                    const originalName = row.dataset.originalName || '';
                                    const originalTelefono = row.dataset.originalTelefono || '';
                                    const hasPassword = Boolean(payload.pass);
                                    const isDeleted = payload.action === 'borrar';
                                    const changed = isNew
                                        || isDeleted
                                        || payload.user !== originalUser
                                        || payload.name !== originalName
                                        || payload.telefono !== originalTelefono
                                        || hasPassword;

                                    if (changed) {
                                        accumulator.push(payload);
                                    }

                                    return accumulator;
                                }, []);
                            }

                            document.addEventListener('click', function (event) {
                                const deleteButton = event.target.closest('.users-row-delete');
                                if (!deleteButton) return;

                                const row = deleteButton.closest('.users-edit-row');
                                const body = row ? row.parentElement : null;
                                if (!row || !body) return;

                                if (row.dataset.isNew === 'true') {
                                    row.remove();
                                    ensureEmptyState(body);
                                    updateRowIndexes(body.closest('.users-role-panel'));
                                    return;
                                }

                                row.classList.toggle('is-pending-delete');
                                deleteButton.textContent = row.classList.contains('is-pending-delete') ? 'Cancelar' : 'Eliminar';
                            });

                            tabs.forEach(function (tab) {
                                tab.addEventListener('click', function () {
                                    showPanel(tab.dataset.usersTab || 'clientes');
                                });
                            });

                            if (addButton) {
                                addButton.addEventListener('click', function () {
                                    showSubform();
                                });
                            }

                            if (cancelSubformButton) {
                                cancelSubformButton.addEventListener('click', function () {
                                    hideSubform();
                                });
                            }

                            cancelSubformFooterButtons.forEach(function (button) {
                                button.addEventListener('click', function () {
                                    hideSubform();
                                });
                            });

                            if (subform) {
                                subform.addEventListener('click', function (event) {
                                    if (event.target && event.target.matches('[data-close-users-modal="true"]')) {
                                        hideSubform();
                                    }
                                });
                            }

                            createForms.forEach(function (createForm) {
                                createForm.addEventListener('submit', function (event) {
                                    event.preventDefault();

                                    const activePanel = getActivePanel();
                                    const body = activePanel ? activePanel.querySelector('tbody[data-users-role]') : null;
                                    if (!body) return;

                                    const formData = new FormData(createForm);
                                    const role = createForm.dataset.createRole || body.dataset.usersRole || 'cliente';
                                    const emptyRow = body.querySelector('.users-empty-row');
                                    if (emptyRow) emptyRow.remove();

                                    body.appendChild(createEditableRowWithValues(role, {
                                        user: String(formData.get('user') || '').trim(),
                                        name: String(formData.get('name') || '').trim(),
                                        telefono: String(formData.get('telefono') || '').trim(),
                                        pass: String(formData.get('pass') || '').trim()
                                    }));
                                    updateRowIndexes(activePanel);
                                    hideSubform();
                                    setFeedback('success', 'La nueva fila se agregó a la tabla. Ahora pulsa Guardar cambios para registrarla.');
                                });
                            });

                            document.addEventListener('keydown', function (event) {
                                if (event.key === 'Escape' && subform && subform.classList.contains('is-open')) {
                                    hideSubform();
                                }
                            });

                            if (saveButton) {
                                saveButton.addEventListener('click', async function () {
                                    const rows = collectChangedRows();
                                    if (!rows.length) {
                                        setFeedback('success', 'No hay cambios pendientes por guardar.');
                                        return;
                                    }

                                    saveButton.disabled = true;
                                    saveButton.textContent = 'Guardando...';

                                    try {
                                        const response = await fetch('/admin/users-inline-save', {
                                            method: 'POST',
                                            headers: {
                                                'Content-Type': 'application/json'
                                            },
                                            body: JSON.stringify({ rows: rows })
                                        });

                                        const result = await response.json();
                                        if (!response.ok || !result.ok) {
                                            throw new Error(result.message || 'No se pudieron guardar los cambios.');
                                        }

                                        const redirectUrl = '/admin?usersExcelStatus=ok&usersExcelSummary=' + encodeURIComponent(result.message || 'Cambios guardados correctamente.');
                                        window.location.href = redirectUrl;
                                    } catch (error) {
                                        setFeedback('error', error.message || 'No se pudieron guardar los cambios.');
                                    } finally {
                                        saveButton.disabled = false;
                                        saveButton.textContent = 'Guardar cambios';
                                    }
                                });
                            }

                            document.querySelectorAll('.users-edit-row').forEach(function (row) {
                                const userInput = row.querySelector('[data-field="user"]');
                                const nameInput = row.querySelector('[data-field="name"]');
                                const phoneInput = row.querySelector('[data-field="telefono"]');
                                row.dataset.originalName = nameInput ? nameInput.value.trim() : '';
                                row.dataset.originalTelefono = phoneInput ? phoneInput.value.trim() : '';
                                row.dataset.originalUser = row.dataset.originalUser || (userInput ? userInput.value.trim() : '');
                            });
                        })();
                    </script>
                </div>

                        </div>
                    </div>

