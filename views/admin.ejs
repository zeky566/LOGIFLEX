            function refreshView() {
                const chofer = driverFilter.value;
                const aliases = getDriverAliases(chofer);

                filtered = chofer
                    ? vehicles.filter(v => aliases.includes(normalizeText(v.conductor_asignado)))
                    : [...vehicles];

                renderVehicleOptions();
                const noData = filtered.length === 0;
                vehicleEmpty.style.display = noData ? 'block' : 'none';

                const selectedIndex = noData ? -1 : 0;
                if (!noData) vehicleSelector.value = '0';
                renderTable(selectedIndex);
                fillPanels(noData ? null : filtered[0]);
            }

            driverFilter.addEventListener('change', refreshView);
            vehicleSelector.addEventListener('change', function () {
                const idx = Number(this.value);
                renderTable(idx);
                fillPanels(filtered[idx]);
            });

            tableBody.addEventListener('click', function (event) {
                const deleteButton = event.target.closest('.vehicle-row-delete');
                if (deleteButton) {
                    const row = deleteButton.closest('.vehicle-edit-row');
                    if (!row) return;

                    if (row.dataset.isNew === 'true') {
                        row.remove();
                        if (!tableBody.querySelector('.vehicle-edit-row')) {
                            tableBody.innerHTML = '<tr><td colspan="7">Sin vehículos registrados para ese chofer.</td></tr>';
                        }
                        return;
                    }

                    row.classList.toggle('is-pending-delete');
                    deleteButton.textContent = row.classList.contains('is-pending-delete') ? 'Cancelar' : 'Eliminar';
                    return;
                }

                const row = event.target.closest('tr[data-index]');
                if (!row) return;
                const idx = Number(row.dataset.index);
                if (idx < 0) return;
                vehicleSelector.value = String(idx);
                renderTable(idx);
                fillPanels(filtered[idx]);
            });

