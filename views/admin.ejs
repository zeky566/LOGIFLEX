            <p>LOGIFLEX <br>
                Dedicada a brindar servicios de transporte y logística confiables y eficientes</p>
        </div>

        <!-- Controles del slider   (< flechas>)-->
        <div class="slider-controls">
            <span class="prev" id="prevBtn">&#10094;</span>
            <span class="next" id="nextBtn">&#10095;</span>
        </div>
    </section>

    <!-- SCRIPT CORREGIDO para el slider -->
    <script>
        // Esperar a que el DOM esté listo
        document.addEventListener('DOMContentLoaded', function () {
            const hero = document.querySelector(".hero");
            const dots = document.querySelectorAll(".dot");
            const prevBtn = document.getElementById("prevBtn");
            const nextBtn = document.getElementById("nextBtn");

            // CORREGIDO: Rutas correctas para las imágenes
            // IMPORTANTE: Asegúrate de que estas imágenes existan en tu carpeta public/
            const images = [
                "/resources/c4.jpg",
                "/resources/c5.jpg",
                "/resources/c6.jpg"
            ];

            let current = 0;
            let intervalId;

            // Función para mostrar la imagen actual
            function mostrarImagen(index) {
                current = index;
                hero.style.backgroundImage = `url('${images[current]}')`;

                // Actualizar dots
                dots.forEach((dot, i) => {
                    if (i === current) {
                        dot.classList.add("active");
                    } else {
                        dot.classList.remove("active");
                    }
                });
            }

            // Avanzar a la siguiente imagen
            function siguienteImagen() {
                current = (current + 1) % images.length;
                mostrarImagen(current);
            }

            // Retroceder a la imagen anterior
            function anteriorImagen() {
                current = (current - 1 + images.length) % images.length;
                mostrarImagen(current);
            }

            // Ir a una imagen específica (por los dots)
            function irAImagen(index) {
                mostrarImagen(index);
                reiniciarIntervalo();
            }

            // Reiniciar el intervalo de cambio automático
            function reiniciarIntervalo() {
                clearInterval(intervalId);
                intervalId = setInterval(siguienteImagen, 5000);
            }

            // Verificar que los elementos existen antes de agregar eventos
            if (nextBtn && prevBtn) {
                nextBtn.addEventListener("click", function () {
                    siguienteImagen();
                    reiniciarIntervalo();
                });

                prevBtn.addEventListener("click", function () {
                    anteriorImagen();
                    reiniciarIntervalo();
                });
            }

            // Event listeners para los dots
            if (dots.length > 0) {
                dots.forEach((dot, index) => {
                    dot.addEventListener("click", () => irAImagen(index));
                });
            }

            // Pausar al hacer hover
            if (hero) {
                hero.addEventListener("mouseenter", () => {
                    clearInterval(intervalId);
                });

                hero.addEventListener("mouseleave", () => {
                    intervalId = setInterval(siguienteImagen, 5000);
                });
            }

            // Inicializar - mostrar primera imagen
            if (images.length > 0) {
                mostrarImagen(0);
                intervalId = setInterval(siguienteImagen, 5000);
            }
        });
    </script>

